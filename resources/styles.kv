# file with common widgets we might need. only one so far, add more if needed
#:import utils kivy.utils

# $ amount input that keeps a static '$' before the actual input
<AmountInput@BoxLayout>:
    orientation: 'horizontal'
    spacing: dp(2)
    size_hint_y: None
    height: dp(40)
    
    text: ti.text.replace('$', '').strip() # cleans text if user put an extra $

    Label:
        text: '$'
        color: utils.get_color_from_hex('#6BB562')
        size_hint_x: None
        width: self.texture_size[0] + dp(5)
        font_size: '18sp'

    TextInput:
        id: ti
        multiline: False
        hint_text: "0.00"
        background_normal: ''
        on_text: root.text = self.text
        halign: 'left'
        padding_y: [self.height / 2.0 - (self.line_height / 2.0), 0]
        canvas.after:
            Color: 
                rgba: utils.get_color_from_hex('#6BB562')
            Line:
                width: 1.2
                rectangle: (self.x, self.y, self.width, self.height)