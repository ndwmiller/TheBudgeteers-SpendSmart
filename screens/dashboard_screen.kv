#:import utils kivy.utils
# Write screen frontend here
<DashboardScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: [118, 40, 118, 40]

        # balance overview
        BoxLayout:
            orientation: 'horizontal'

            # balance
            BoxLayout:
                orientation: 'vertical'

                Label:
                    canvas.before:
                        Color:
                            rgba: utils.get_color_from_hex('#D7D7D7')
                        Rectangle:
                            pos: self.pos
                            size: self.size

                    # Green Outline
                    canvas.after:
                        Color: 
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: 1.2
                            rectangle: (self.x, self.y, self.width, self.height)

                Label:
                    canvas.before:
                        Color:
                            rgba: utils.get_color_from_hex('#D7D7D7')
                        Rectangle:
                            pos: self.pos
                            size: self.size

                    # Green Outline
                    canvas.after:
                        Color: 
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: 1.2
                            rectangle: (self.x, self.y, self.width, self.height)

            # income
            BoxLayout:
                orientation: 'vertical'

                Label:
                    canvas.before:
                        Color:
                            rgba: utils.get_color_from_hex('#D7D7D7')
                        Rectangle:
                            pos: self.pos
                            size: self.size

                    # Green Outline
                    canvas.after:
                        Color: 
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: 1.2
                            rectangle: (self.x, self.y, self.width, self.height)

                Label:
                    canvas.before:
                        Color:
                            rgba: utils.get_color_from_hex('#D7D7D7')
                        Rectangle:
                            pos: self.pos
                            size: self.size

                    # Green Outline
                    canvas.after:
                        Color: 
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: 1.2
                            rectangle: (self.x, self.y, self.width, self.height)

            # expenses
            BoxLayout:
                orientation: 'vertical'

                Label:
                    canvas.before:
                        Color:
                            rgba: utils.get_color_from_hex('#D7D7D7')
                        Rectangle:
                            pos: self.pos
                            size: self.size

                    # Green Outline
                    canvas.after:
                        Color: 
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: 1.2
                            rectangle: (self.x, self.y, self.width, self.height)

                Label:
                    canvas.before:
                        Color:
                            rgba: utils.get_color_from_hex('#D7D7D7')
                        Rectangle:
                            pos: self.pos
                            size: self.size

                    # Green Outline
                    canvas.after:
                        Color: 
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: 1.2
                            rectangle: (self.x, self.y, self.width, self.height)

        Widget:
            size_hint_y: None
            height: '58dp'

        # the other half of it
        BoxLayout:
            orientation: 'horizontal'

            # Upcoming bills layout
            BoxLayout:
                orientation: 'vertical'

                Label:
                    canvas.before:
                        Color:
                            rgba: utils.get_color_from_hex('#D7D7D7')
                        Rectangle:
                            pos: self.pos
                            size: self.size

                    # Green Outline
                    canvas.after:
                        Color: 
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: 1.2
                            rectangle: (self.x, self.y, self.width, self.height)

                # Upcoming bills container
                BoxLayout:
                    orientation: 'vertical'
                    canvas.before:
                        Color:
                            rgba: utils.get_color_from_hex('#D7D7D7')
                        Rectangle:
                            pos: self.pos
                            size: self.size

                    # Green Outline
                    canvas.after:
                        Color: 
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: 1.2
                            rectangle: (self.x, self.y, self.width, self.height)

            # Budget | Categories | Analytics
            BoxLayout:
                orientation: 'vertical'

                # Budget | Categories
                BoxLayout:
                    orientation: 'horizontal'

                    # Monthly budget
                    BoxLayout:
                        orientation: 'vertical'

                        Label:
                            canvas.before:
                                Color:
                                    rgba: utils.get_color_from_hex('#D7D7D7')
                                Rectangle:
                                    pos: self.pos
                                    size: self.size

                            # Green Outline
                            canvas.after:
                                Color: 
                                    rgba: utils.get_color_from_hex('#6BB562')
                                Line:
                                    width: 1.2
                                    rectangle: (self.x, self.y, self.width, self.height)

                        Label:
                            canvas.before:
                                Color:
                                    rgba: utils.get_color_from_hex('#D7D7D7')
                                Rectangle:
                                    pos: self.pos
                                    size: self.size

                            # Green Outline
                            canvas.after:
                                Color: 
                                    rgba: utils.get_color_from_hex('#6BB562')
                                Line:
                                    width: 1.2
                                    rectangle: (self.x, self.y, self.width, self.height)

                    # Categories Layout
                    BoxLayout:
                        orientation: 'vertical'

                        Label:
                            canvas.before:
                                Color:
                                    rgba: utils.get_color_from_hex('#D7D7D7')
                                Rectangle:
                                    pos: self.pos
                                    size: self.size

                            # Green Outline
                            canvas.after:
                                Color: 
                                    rgba: utils.get_color_from_hex('#6BB562')
                                Line:
                                    width: 1.2
                                    rectangle: (self.x, self.y, self.width, self.height)

                        # Categories container
                        BoxLayout:
                            orientation: 'vertical'

                            canvas.before:
                                Color:
                                    rgba: utils.get_color_from_hex('#D7D7D7')
                                Rectangle:
                                    pos: self.pos
                                    size: self.size

                            # Green Outline
                            canvas.after:
                                Color: 
                                    rgba: utils.get_color_from_hex('#6BB562')
                                Line:
                                    width: 1.2
                                    rectangle: (self.x, self.y, self.width, self.height)

                # Analytics layout
                BoxLayout:
                    orientation: 'horizontal'

                    # This week layout
                    BoxLayout:
                        orientation: 'vertical'

                        # Avg expenses
                        BoxLayout:
                            orientation: 'vertical'
                            canvas.before:
                                Color:
                                    rgba: utils.get_color_from_hex('#D7D7D7')
                                Rectangle:
                                    pos: self.pos
                                    size: self.size

                            # Green Outline
                            canvas.after:
                                Color: 
                                    rgba: utils.get_color_from_hex('#6BB562')
                                Line:
                                    width: 1.2
                                    rectangle: (self.x, self.y, self.width, self.height)

                        # highest cat
                        BoxLayout:
                            orientation: 'horizontal'
                            canvas.before:
                                Color:
                                    rgba: utils.get_color_from_hex('#D7D7D7')
                                Rectangle:
                                    pos: self.pos
                                    size: self.size

                            # Green Outline
                            canvas.after:
                                Color: 
                                    rgba: utils.get_color_from_hex('#6BB562')
                                Line:
                                    width: 1.2
                                    rectangle: (self.x, self.y, self.width, self.height)

                    # Last week layout
                    BoxLayout:
                        orientation: 'vertical'

                        # Avg expenses
                        BoxLayout:
                            orientation: 'vertical'
                            canvas.before:
                                Color:
                                    rgba: utils.get_color_from_hex('#D7D7D7')
                                Rectangle:
                                    pos: self.pos
                                    size: self.size

                            # Green Outline
                            canvas.after:
                                Color: 
                                    rgba: utils.get_color_from_hex('#6BB562')
                                Line:
                                    width: 1.2
                                    rectangle: (self.x, self.y, self.width, self.height)

                        # highest cat
                        BoxLayout:
                            orientation: 'horizontal'
                            canvas.before:
                                Color:
                                    rgba: utils.get_color_from_hex('#D7D7D7')
                                Rectangle:
                                    pos: self.pos
                                    size: self.size

                            # Green Outline
                            canvas.after:
                                Color: 
                                    rgba: utils.get_color_from_hex('#6BB562')
                                Line:
                                    width: 1.2
                                    rectangle: (self.x, self.y, self.width, self.height)
