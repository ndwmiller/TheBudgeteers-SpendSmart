                                id: cat_container
                                size_hint_y: None
                                height: self.minimum_height
                                spacing: dp(5)

                            Widget:
                                size_hint_y: 1

                # Analytics layout
                BoxLayout:
                    orientation: 'horizontal'

                    # This week layout
                    BoxLayout:
                        orientation: 'vertical'

                        # Avg expenses
                        BoxLayout:
                            orientation: 'vertical'
                            padding: [15, 5, 10, 35]
