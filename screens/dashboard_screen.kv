            # Budget | Categories | Analytics
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.665

                # Budget | Categories
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: 1.1

                    # Monthly budget
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_x: 0.3

