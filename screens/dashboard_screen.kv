#:import utils kivy.utils

# Bill Element
<BillElement@BoxLayout>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(60)
    padding: [dp(15), dp(10)] 
    spacing: dp(20)
    
    bill_name: "Example"
    bill_date: "XX/XX/XXXX"
    bill_amount: "XXX.XX"

    # Outline and Background
    canvas.before:
        Color:
            rgba: utils.get_color_from_hex('#6BB562')
        Line:
            width: dp(1.5)
            rounded_rectangle: (self.x, self.y, self.width, self.height, dp(10))
        
        Color:
            rgba: utils.get_color_from_hex('#D7D7D7')
        RoundedRectangle:
            pos: self.x + dp(1), self.y + dp(1)
            size: self.width - dp(2), self.height - dp(2)
            radius: [dp(10)]

    # Trash Icon Button
    Button:
        size_hint: None, None
        size: dp(25), dp(25)
        pos_hint: {'center_y': .5}
        background_color: 0, 0, 0, 0  # Makes button invisible
        on_release: root.parent.remove_widget(root)

        Image:
            source: app.base_path + '/resources/Images/trash_icon.png'
            center_x: self.parent.center_x
            center_y: self.parent.center_y
            size: dp(25), dp(25)
            allow_stretch: True
            keep_ratio: True

    # Name and Date
    BoxLayout:
        orientation: 'vertical'
        pos_hint: {'center_y': .5}
        size_hint_x: None
        width: "130dp"
        Label:
            text: root.bill_name
            color: utils.get_color_from_hex('#97C392') # CHANGE TO #6BB562 WHEN NOT EMPTY, #97C392 WHEN EMPTY
            font_size: '22sp'
            halign: 'left'
            valign: 'bottom'
            text_size: self.size

        Label:
            text: root.bill_date
            color: utils.get_color_from_hex('#97C392') # CHANGE TO #6BB562 WHEN NOT EMPTY, #97C392 WHEN EMPTY
            font_size: '18sp'
            halign: 'left'
            valign: 'top'
            text_size: self.size

    # Bill Amount
    Label:
        pos_hint: { 'center_x': .5, 'center_y': .5 }
        text: "$ " + root.bill_amount 
        color: utils.get_color_from_hex('#97C392') # CHANGE TO #6BB562 WHEN NOT EMPTY, #97C392 WHEN EMPTY
        font_size: '18sp'
        halign: 'center'
        valign: 'middle'
        text_size: self.size
        #size_hint_x: 0.2
        size_hint_y: None
        height: '30dp'

        canvas.before:
            Color:
                rgba: utils.get_color_from_hex('#ffffff')
            Rectangle:
                pos: self.pos
                size: self.size

        # Green Outline
        canvas.after:
            Color: 
                rgba: utils.get_color_from_hex('#6BB562')
            Line:
                width: 1.2
                rectangle: (self.x, self.y, self.width, self.height)

<DashboardScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: [118, 40, 118, 40]

        # balance overview
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: '130dp'

            # balance
            BoxLayout:
                orientation: 'vertical'

                Label:
                    text: "Remaining Balance"
                    font_size: '20sp'
                    color: utils.get_color_from_hex('#656565')
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                    size_hint: None, None
                    width: '220dp'
                    height: '30dp'

                    canvas.before:
                        Color:
                            rgba: utils.get_color_from_hex('#D7D7D7')
                        Rectangle:
                            pos: self.pos
                            size: self.size

                    # Green Outline
                    canvas.after:
                        Color: 
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: 1.2
                            rectangle: (self.x, self.y, self.width, self.height)

                # Remaining Balance Amount
                Label:
                    text: "$ " + "XXXXX.XX" # CHANGE THIS TO CHANGE SHOWN AMOUNT
                    bold: True
                    font_size: '34sp'
                    color: utils.get_color_from_hex('#6BB562')
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size

                    canvas.before:
                        Color:
                            rgba: utils.get_color_from_hex('#D7D7D7')
                        Rectangle:
                            pos: self.pos
