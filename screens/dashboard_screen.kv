#:import utils kivy.utils
# Write screen frontend here
<DashboardScreen>:
    BoxLayout:
        orientation: 'vertical'

        # balance overview
        BoxLayout:
            orientation: 'horizontal'

            # balance
            BoxLayout:
                orientation: 'vertical'

                # Label

                # Label

            # income
            BoxLayout:
                orientation: 'vertical'

                # Label

                # Label

            # expenses
            BoxLayout:
                orientation: 'vertical'

                # Label

                # Label

        # the other half of it
        BoxLayout:
            orientation: 'horizontal'

            # Upcoming bills layout
            BoxLayout:
                orientation: 'vertical'

                # Label

                # Upcoming bills container
                BoxLayout:
                    orientation: 'vertical'

            # Budget | Categories | Analytics
            BoxLayout:
                orientation: 'vertical'

                # Budget | Categories
                BoxLayout:
                    orientation: 'horizontal'

                    # Monthly budget
                    BoxLayout:
                        orientation: 'vertical'

                        # Label

                        # Label

                    # Categories Layout
                    BoxLayout:
                        orientation: 'vertical'

                        # Label

                        # Categories container
                        BoxLayout:
                            orientation: 'vertical'

                # Analytics layout
                BoxLayout:
                    orientation: 'horizontal'

                    # This week layout
                    BoxLayout:
                        orientation: 'vertical'

                        # Avg expenses
                        BoxLayout:
                            orientation: 'vertical'

                        # highest cat
                        BoxLayout:
                            orientation: 'horizontal'

                    # Last week layout
                    BoxLayout:
                        orientation: 'vertical'

                        # Avg expenses
                        BoxLayout:
                            orientation: 'vertical'

                        # highest cat
                        BoxLayout:
                            orientation: 'horizontal'
