                            valign: 'middle'
                            text_size: self.size
                            size_hint: None, None
                            width: '180dp'
                            height: '30dp'

                            canvas.before:
                                Color:
                                    rgba: utils.get_color_from_hex('#D7D7D7')
                                Rectangle:
                                    pos: self.pos
                                    size: self.size

                            # Green Outline
                            canvas.after:
                                Color: 
                                    rgba: utils.get_color_from_hex('#6BB562')
                                Line:
                                    width: 1.2
                                    rectangle: (self.x, self.y, self.width, self.height)

                        Label:
                            text: "$ " + root.monthly_budget()

