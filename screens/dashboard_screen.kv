                                halign: 'left'
                                valign: 'middle'
                                text_size: self.size
                                size_hint_x: 0.35
                                size_hint_y: None
                                height: '30dp'

                            # Highest Spending Amount
                            Label:
                                pos_hint: { 'center_x': .5, 'center_y': .5 }
                                text: "$ " + root.high_cat_amount_this_week()

                                color: utils.get_color_from_hex('#6BB562') # CHANGE TO #6BB562 WHEN NOT EMPTY, #6BB562 WHEN EMPTY
                                font_size: '18sp'
                                halign: 'center'
                                valign: 'middle'
                                text_size: self.size
                                size_hint_x: 0.2
                                size_hint_y: None
                                height: '30dp'

                                canvas.before:
                                    Color:
                                        rgba: (1, 1, 1, 1) if app.theme == 'light' else (0.302, 0.302, 0.302, 1)
                                    Rectangle:
                                        pos: self.pos
                                        size: self.size

                                # Green Outline
                                canvas.after:
                                    Color:
                                        rgba: utils.get_color_from_hex('#6BB562')
                                    Line:
                                        width: 1.2
                                        rectangle: (self.x, self.y, self.width, self.height)

                    # Last week layout
                    BoxLayout:
                        orientation: 'vertical'

                        # Avg expenses
                        BoxLayout:
                            orientation: 'vertical'
                            padding: [15, 5, 10, 35]
                            size_hint_y: 0.65
                            canvas.before:
                                Color:
                                    rgba: utils.get_color_from_hex('#D7D7D7')
                                Rectangle:
                                    pos: self.pos
                                    size: self.size

                            # Green Outline
                            canvas.after:
                                Color: 
                                    rgba: utils.get_color_from_hex('#6BB562')
                                Line:
                                    width: 1.2
                                    rectangle: (self.x, self.y, self.width, self.height)

                            # Last week header
                            BoxLayout:
                                orientation: 'horizontal'
                                size_hint_y: None
                                height: '30dp'

                                Label:
                                    pos_hint: { 'center_x': .5, 'center_y': .5 }
                                    markup: True
                                    text: "[u]Last Week[/u]"
                                    font_size: '18sp'
                                    color: utils.get_color_from_hex('#6BB562')
                                    halign: 'left'
                                    valign: 'middle'
                                    text_size: self.size
                                    size_hint_x: 0.35
                                    size_hint_y: None
                                    height: '30dp'
                                Widget:
                            
                            # Avg Day Expenses Row
                            BoxLayout:
                                orientation: 'horizontal'

                                # Avg Day Expenses Text
                                Label:
                                    pos_hint: { 'center_x': .5, 'center_y': .5 }
                                    text: "Avg. Day Expenses:"
                                    font_size: '18sp'
                                    color: utils.get_color_from_hex('#6BB562')
                                    halign: 'left'
                                    valign: 'middle'
                                    text_size: self.size
                                    size_hint_x: 0.35
                                    size_hint_y: None
                                    height: '30dp'

                                # Avg Day Expenses Amount
                                Label:
                                    pos_hint: { 'center_x': .5, 'center_y': .5 }
                                    text: "$ " + root.day_expenses_last_week()

                                    color: utils.get_color_from_hex('#6BB562') # CHANGE TO #6BB562 WHEN NOT EMPTY, #6BB562 WHEN EMPTY
                                    font_size: '18sp'
                                    halign: 'center'
                                    valign: 'middle'
                                    text_size: self.size
                                    size_hint_x: 0.2
                                    size_hint_y: None
                                    height: '30dp'

                                    canvas.before:
                                        Color:
                                            rgba: (1, 1, 1, 1) if app.theme == 'light' else (0.302, 0.302, 0.302, 1)
                                        Rectangle:
                                            pos: self.pos
                                            size: self.size

                                    # Green Outline
                                    canvas.after:
                                        Color: 
                                            rgba: utils.get_color_from_hex('#6BB562')
                                        Line:
                                            width: 1.2
                                            rectangle: (self.x, self.y, self.width, self.height)

                            # Week Expenses Row
                            BoxLayout:
                                orientation: 'horizontal'

                                # Week Expenses Text
                                Label:
                                    pos_hint: { 'center_x': .5, 'center_y': .5 }
                                    text: "Weely Expenses:"
                                    font_size: '18sp'
                                    color: utils.get_color_from_hex('#6BB562')
                                    halign: 'left'
                                    valign: 'middle'
                                    text_size: self.size
                                    size_hint_x: 0.35
                                    size_hint_y: None
                                    height: '30dp'

                                # Week Expenses Amount
                                Label:
                                    pos_hint: { 'center_x': .5, 'center_y': .5 }
                                    text: "$ " + root.week_expenses_last_week()

                                    color: utils.get_color_from_hex('#6BB562') # CHANGE TO #6BB562 WHEN NOT EMPTY, #6BB562 WHEN EMPTY
                                    font_size: '18sp'
                                    halign: 'center'
                                    valign: 'middle'
                                    text_size: self.size
                                    size_hint_x: 0.2
                                    size_hint_y: None
                                    height: '30dp'

                                    canvas.before:
                                        Color:
                                            rgba: (1, 1, 1, 1) if app.theme == 'light' else (0.302, 0.302, 0.302, 1)
                                        Rectangle:
                                            pos: self.pos
                                            size: self.size

                                    # Green Outline
                                    canvas.after:
                                        Color: 
                                            rgba: utils.get_color_from_hex('#6BB562')
                                        Line:
                                            width: 1.2
                                            rectangle: (self.x, self.y, self.width, self.height)

                        # Highest cat layout
                        BoxLayout:
                            orientation: 'horizontal'
                            size_hint_y: 0.35
                            padding: [15, 10, 10, 10]
                            canvas.before:
                                Color:
                                    rgba: utils.get_color_from_hex('#D7D7D7')
                                Rectangle:
                                    pos: self.pos
                                    size: self.size

                            # Green Outline
                            canvas.after:
                                Color: 
                                    rgba: utils.get_color_from_hex('#6BB562')
                                Line:
                                    width: 1.2
                                    rectangle: (self.x, self.y, self.width, self.height)

                            # Highest Spending Cat
                            Label:
                                pos_hint: { 'center_x': .5, 'center_y': .5 }
                                text: root.high_cat_name_last_week()

                                font_size: '18sp'
                                color: utils.get_color_from_hex('#6BB562') # CHANGE TO #6BB562 WHEN NOT EMPTY, #6BB562 WHEN EMPTY
                                halign: 'left'
                                valign: 'middle'
                                text_size: self.size
                                size_hint_x: 0.35
                                size_hint_y: None
                                height: '30dp'

                            # Highest Spending Amount
                            Label:
                                pos_hint: { 'center_x': .5, 'center_y': .5 }
                                text: "$ " + root.high_cat_amount_last_week()

                                color: utils.get_color_from_hex('#6BB562') # CHANGE TO #6BB562 WHEN NOT EMPTY, #6BB562 WHEN EMPTY
                                font_size: '18sp'
                                halign: 'center'
                                valign: 'middle'
                                text_size: self.size
                                size_hint_x: 0.2
                                size_hint_y: None
                                height: '30dp'

                                canvas.before:
                                    Color:
                                        rgba: (1, 1, 1, 1) if app.theme == 'light' else (0.302, 0.302, 0.302, 1)
                                    Rectangle:
                                        pos: self.pos
                                        size: self.size

                                # Green Outline
                                canvas.after:
                                    Color:
                                        rgba: utils.get_color_from_hex('#6BB562')
                                    Line:
                                        width: 1.2
                                        rectangle: (self.x, self.y, self.width, self.height)
    # Floating Labels
    FloatLayout:
        pos_hint: { 'center_x': .5, 'center_y': .5 }

        # Analytics label        
        Label:
            pos_hint: { 'center_x': .394, 'center_y': .379 }
            text: "Analytics"
            font_size: '20sp'
            color: utils.get_color_from_hex('#656565')
            halign: 'center'
            valign: 'middle'
            text_size: self.size
            size_hint: None, None
            width: '100dp'
            height: '30dp'

            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex('#D7D7D7')
                Rectangle:
                    pos: self.pos
                    size: self.size

            # Green Outline
            canvas.after:
                Color: 
                    rgba: utils.get_color_from_hex('#6BB562')
                Line:
                    width: 1.2
                    rectangle: (self.x, self.y, self.width, self.height)

        # Highest Spending Label This Week
        Label:
            pos_hint: { 'center_x': .41, 'center_y': .166 }
            text: "Highest Spending"
            font_size: '16sp'
            color: utils.get_color_from_hex('#656565')
            halign: 'center'
            valign: 'middle'
            text_size: self.size
            size_hint: None, None
            width: '140dp'
            height: '20dp'

            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex('#D7D7D7')
                Rectangle:
                    pos: self.pos
                    size: self.size

            # Green Outline
            canvas.after:
                Color: 
                    rgba: utils.get_color_from_hex('#6BB562')
                Line:
                    width: 1.2
                    rectangle: (self.x, self.y, self.width, self.height)

        # Highest Spending Label Last Week
        Label:
            pos_hint: { 'center_x': .702, 'center_y': .166 }
            text: "Highest Spending"
            font_size: '16sp'
            color: utils.get_color_from_hex('#656565')
            halign: 'center'
            valign: 'middle'
            text_size: self.size
            size_hint: None, None
            width: '140dp'
            height: '20dp'

            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex('#D7D7D7')
                Rectangle:
                    pos: self.pos
                    size: self.size

            # Green Outline
            canvas.after:
                Color: 
                    rgba: utils.get_color_from_hex('#6BB562')
                Line:
                    width: 1.2
                    rectangle: (self.x, self.y, self.width, self.height)
