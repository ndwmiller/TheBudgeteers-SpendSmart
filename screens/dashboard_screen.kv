                        # Highest cat layout
                        BoxLayout:
                            orientation: 'horizontal'
                            size_hint_y: 0.35
                            padding: [15, 10, 10, 10]
                            canvas.before:
                                Color:
                                    rgba: utils.get_color_from_hex('#D7D7D7')
                                Rectangle:
                                    pos: self.pos
                                    size: self.size

                            # Green Outline
                            canvas.after:
                                Color: 
                                    rgba: utils.get_color_from_hex('#6BB562')
                                Line:
                                    width: 1.2
