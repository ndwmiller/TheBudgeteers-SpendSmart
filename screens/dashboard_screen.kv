                        do_scroll_y: True
                        
                        BoxLayout:
                            id: bill_container
                            orientation: 'vertical'
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(10)
                            padding: dp(10)

                    # Add button
                    BoxLayout:
