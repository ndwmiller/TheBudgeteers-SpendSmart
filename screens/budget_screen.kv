#:import utils kivy.utils
#:import dp kivy.metrics.dp

<BudgetValueLabel@Label>:
    color: utils.get_color_from_hex('#519D4A')
    font_size: '30sp'
    bold: True
    halign: 'center'
    valign: 'middle'
    text_size: self.size

<BudgetChipLabel@Label>:
    color: utils.get_color_from_hex('#519D4A')
    font_size: '20sp'
    bold: False
    halign: 'center'
    valign: 'middle'
    text_size: self.size
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: utils.get_color_from_hex('#6BB562')
        Line:
            width: 1.2
            rectangle: (self.x, self.y, self.width, self.height)

<BudgetScreen>:
    FloatLayout:
        canvas.before:
            Color:
                rgba: utils.get_color_from_hex('#4D4D4D')
            Rectangle:
                pos: self.pos
                size: self.size

        # === Current & Monthly Budget Cards ===
        FloatLayout:
            size_hint: None, None
            width: min(root.width * 0.78, dp(860))
            height: dp(125)
            pos_hint: {'center_x': 0.5, 'top': 0.79}

            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex('#D7D7D7')
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: utils.get_color_from_hex('#6BB562')
                Line:
                    width: 1.4
                    rectangle: (self.x, self.y, self.width, self.height)
                Line:
                    width: 1.2
                    points: (self.center_x, self.y, self.center_x, self.top)

            # Current Budget
            Label:
                text: '[u]Current Budget[/u]'
                markup: True
                size_hint: None, None
                size: dp(140), dp(28)
                pos_hint: {'center_x': 0.25, 'top': 1.10}
                color: utils.get_color_from_hex('#656565')
                font_size: '14sp'
                bold: False
                halign: 'center'
                valign: 'middle'
                text_size: self.size
                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex('#D7D7D7')
                    Rectangle:
                        pos: self.pos
                        size: self.size
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)

            BudgetValueLabel:
                text: root.current_budget
                size_hint: 0.5, 1
                pos_hint: {'x': 0, 'y': 0}

            # Monthly Budget
            Label:
                text: '[u]Monthly Budget[/u]'
                markup: True
                size_hint: None, None
                size: dp(140), dp(28)
                pos_hint: {'center_x': 0.75, 'top': 1.10}
                color: utils.get_color_from_hex('#656565')
                font_size: '14sp'
                bold: False
                halign: 'center'
                valign: 'middle'
                text_size: self.size
                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex('#D7D7D7')
                    Rectangle:
                        pos: self.pos
                        size: self.size
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)

            BudgetValueLabel:
                text: root.monthly_budget
                size_hint: 0.5, 1
                pos_hint: {'x': 0.5, 'y': 0}

        Widget:
            size_hint: None, None
            size: min(root.width * 0.78, dp(860)), dp(16)
            pos_hint: {'center_x': 0.5, 'top': 0.62}

        # === Categories Section ===
        FloatLayout:
            size_hint: None, None
            width: min(root.width * 0.78, dp(860))
            height: dp(250)
            pos_hint: {'center_x': 0.5, 'top': 0.52}

            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex('#D7D7D7')
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: utils.get_color_from_hex('#6BB562')
                Line:
                    width: 1.4
                    rectangle: (self.x, self.y, self.width, self.height)

            # Categories Title
            Label:
                text: '[u]Categories[/u]'
                markup: True
                size_hint: None, None
                size: dp(130), dp(28)
                pos_hint: {'center_x': 0.5, 'y': 1}
                color: utils.get_color_from_hex('#656565')
                font_size: '14sp'
                bold: False
                halign: 'center'
                valign: 'middle'
                text_size: self.size
                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex('#D7D7D7')
                    Rectangle:
                        pos: self.pos
                        size: self.size
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)

            # Column Headers
            BoxLayout:
                orientation: 'horizontal'
                size_hint: None, None
                size: dp(560), dp(26)
                pos_hint: {'center_x': 0.53, 'top': 0.90}
                spacing: dp(10)

                Label:
                    text: '[u]Categories[/u]'
                    markup: True
                    color: utils.get_color_from_hex('#519D4A')
                    font_size: '17sp'
                    bold: False
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_x: 0.46

                Label:
                    text: '[u]Percent[/u]'
                    markup: True
                    color: utils.get_color_from_hex('#519D4A')
                    font_size: '16sp'
                    bold: False
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_x: 0.23

                Label:
                    text: '[u]Remaining[/u]'
                    markup: True
                    color: utils.get_color_from_hex('#519D4A')
                    font_size: '16sp'
                    bold: False
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_x: 0.31

            # Categories Rows
            GridLayout:
                id: categories_grid
                cols: 1
                spacing: dp(8)
                size_hint: None, None
                size: dp(560), dp(145)
                pos_hint: {'center_x': 0.53, 'top': 0.77}

        # Edit Budget Button
        Button:
            text: 'Edit Budget'
            size_hint: None, None
            size: dp(95), dp(24)
            pos_hint: {'center_x': 0.5, 'y': 0.04}
            background_normal: ''
            background_down: ''
            background_color: utils.get_color_from_hex('#DAFFC8')
            color: utils.get_color_from_hex('#519D4A')
            font_size: '14sp'
            bold: False
            on_release: root.open_edit_budget()
            canvas.after:
                Color:
                    rgba: utils.get_color_from_hex('#6BB562')
                Line:
                    width: 1.2
                    rectangle: (self.x, self.y, self.width, self.height)
