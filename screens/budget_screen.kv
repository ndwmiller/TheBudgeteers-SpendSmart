#:import utils kivy.utils
#:import dp kivy.metrics.dp

<BudgetValueLabel@Label>:
    color: utils.get_color_from_hex('#519D4A')
    font_size: '30sp'
    bold: True
    halign: 'center'
    valign: 'middle'
    text_size: self.size

<BudgetChipLabel@Label>:
    color: utils.get_color_from_hex('#519D4A')
    font_size: '20sp'
    bold: False
    halign: 'center'
    valign: 'middle'
    text_size: self.size
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: utils.get_color_from_hex('#6BB562')
        Line:
            width: 1.2
            rectangle: (self.x, self.y, self.width, self.height)

<BudgetCategoryRow@BoxLayout>:
    orientation: 'horizontal'
    spacing: dp(20)
    size_hint_y: None
    height: dp(26)

    Label:
        text: '• ' + root.cat_name
        color: utils.get_color_from_hex('#519D4A')
        font_size: '16sp'
        halign: 'left'
        valign: 'middle'
        text_size: self.size
        size_hint_x: 0.33
        padding: [dp(20), 0]

    AnchorLayout:
        size_hint_x: 0.33
        anchor_x: 'center'
        anchor_y: 'center'
        BudgetChipLabel:
            text: root.cat_percent + '%'
            size_hint: None, 1
            width: dp(105)

    AnchorLayout:
        size_hint_x: 0.34
        anchor_x: 'center'
        anchor_y: 'center'
        BudgetChipLabel:
            text: '$' + root.cat_remaining
            size_hint: None, 1
            width: dp(120)

<BudgetScreen>:
    FloatLayout:
        canvas.before:
            Color:
                rgba: utils.get_color_from_hex('#4D4D4D')
            Rectangle:
                pos: self.pos
                size: self.size

        # === Current & Monthly Budget Cards ===
        FloatLayout:
            size_hint: None, None
            width: min(root.width * 0.78, dp(860))
            height: dp(125)
            pos_hint: {'center_x': 0.5, 'top': 0.84}

            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex('#D7D7D7')
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: utils.get_color_from_hex('#6BB562')
                Line:
                    width: 1.4
                    rectangle: (self.x, self.y, self.width, self.height)
                Line:
                    width: 1.2
                    points: (self.center_x, self.y, self.center_x, self.top)

            # Remaining Budget
            Label:
                text: 'Remaining Budget'
                size_hint: None, None
                size: dp(180), dp(30)
                pos_hint: {'center_x': 0.25, 'top': 1.24}
                color: utils.get_color_from_hex('#656565')
                font_size: '20sp'
                bold: False
                halign: 'center'
                valign: 'middle'
                text_size: self.size
                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex('#D7D7D7')
                    Rectangle:
                        pos: self.pos
                        size: self.size
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)

            BudgetValueLabel:
                text: '$' + root.remaining_budget
                size_hint: 0.5, 1
                pos_hint: {'x': 0, 'y': 0}

            # Monthly Budget
            Label:
                text: 'Monthly Budget'
                size_hint: None, None
                size: dp(180), dp(30)
                pos_hint: {'center_x': 0.75, 'top': 1.24}
                color: utils.get_color_from_hex('#656565')
                font_size: '20sp'
                bold: False
                halign: 'center'
                valign: 'middle'
                text_size: self.size
                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex('#D7D7D7')
                    Rectangle:
                        pos: self.pos
                        size: self.size
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)

            BudgetValueLabel:
                text: '$' + root.monthly_budget
                size_hint: 0.5, 1
                pos_hint: {'x': 0.5, 'y': 0}

        Widget:
            size_hint_y: None
            height: dp(30)

        # === Categories Section ===
        FloatLayout:
            size_hint: None, None
            width: min(root.width * 0.78, dp(860))
            height: dp(300)
            pos_hint: {'center_x': 0.5, 'top': 0.57}

            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex('#D7D7D7')
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: utils.get_color_from_hex('#6BB562')
                Line:
                    width: 1.4
                    rectangle: (self.x, self.y, self.width, self.height)

            # Categories Title
            Label:
                text: 'Categories'
                size_hint: None, None
                size: dp(150), dp(30)
                pos_hint: {'center_x': 0.5, 'y': 1}
                color: utils.get_color_from_hex('#656565')
                font_size: '20sp'
                bold: False
                halign: 'center'
                valign: 'middle'
                text_size: self.size
                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex('#D7D7D7')
                    Rectangle:
                        pos: self.pos
                        size: self.size
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)

            # Empty state label
            Label:
                text: "You have no categories yet. Add one!"
                opacity: 0 if root.has_categories else 1
                color: utils.get_color_from_hex('#519D4A')
                font_size: '16sp'
                halign: 'center'
                valign: 'middle'
                text_size: self.size
                pos_hint: {'center_x': 0.5, 'center_y': 0.45}
                size_hint: None, None
                size: dp(400), dp(40)

            # Column Headers
            BoxLayout:
                orientation: 'horizontal'
                opacity: 1 if root.has_categories else 0
                size_hint: None, None
                size: dp(560), dp(26)
                pos_hint: {'center_x': 0.5, 'top': 0.90}
                spacing: dp(10)

                Widget:
                    size_hint_x: 0.33

                Label:
                    text: '[u]Percent[/u]'
                    markup: True
                    color: utils.get_color_from_hex('#519D4A')
                    font_size: '16sp'
                    bold: False
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_x: 0.33

                Label:
                    text: '  [u]Remaining[/u]'
                    markup: True
                    color: utils.get_color_from_hex('#519D4A')
                    font_size: '16sp'
                    bold: False
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_x: 0.34

            # Categories Rows
            GridLayout:
                id: categories_grid
                cols: 1
                spacing: dp(8)
                size_hint: None, None
                size: dp(560), dp(145)
                pos_hint: {'center_x': 0.5, 'top': 0.77}

            # Edit Budget Button
            Button:
                text: 'Edit Budget'
                size_hint: None, None
                size: dp(95), dp(24)
                pos_hint: {'center_x': 0.5, 'y': 0.04}
                background_normal: ''
                background_down: ''
                background_color: utils.get_color_from_hex('#DAFFC8')
                color: utils.get_color_from_hex('#519D4A')
                font_size: '14sp'
                bold: False
                on_release: root.open_edit_budget()
                canvas.after:
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)
