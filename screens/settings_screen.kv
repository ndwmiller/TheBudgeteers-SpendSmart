#:import utils kivy.utils
#:import os os

# ─────────────────────────────────────────────────────────────────
#  SettingsScreen
#  Author: Sakhi Hussain
#
#  NOTE: This file is loaded by settings_screen.py via Builder.load_file().
#        Do NOT add it to app_shell.kv's #:include list.
# ─────────────────────────────────────────────────────────────────

<SettingsScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: ('40dp', '30dp', '40dp', '30dp')
        spacing: '20dp'

        canvas.before:
            Color:
                rgba: (0.302, 0.302, 0.302, 1)
            Rectangle:
                pos: self.pos
                size: self.size

        # ── Panel card ─────────────────────────────────────────
        BoxLayout:
            orientation: 'vertical'
            spacing: 0

            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex('#2a2a2a')
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [16]
                Color:
                    rgba: utils.get_color_from_hex('#444444')
                Line:
                    rounded_rectangle: [self.x, self.y, self.width, self.height, 16]
                    width: 1.2

            # ── Panel header ───────────────────────────────────
            BoxLayout:
                size_hint_y: None
                height: '70dp'
                padding: ['20dp', '0dp']
                spacing: '14dp'

                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex('#333333')
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [16, 16, 0, 0]
                    Color:
                        rgba: utils.get_color_from_hex('#444444')
                    Line:
                        points: [self.x, self.y, self.x + self.width, self.y]
                        width: 1

                Image:
                    source: app.base_path + '/resources/Images/settings_icon.png'
                    size_hint: (None, None)
                    size: ('32dp', '32dp')
                    pos_hint: {'center_y': 0.5}
                    allow_stretch: True
                    keep_ratio: True

                Label:
                    text: 'Settings'
                    font_size: '26sp'
                    bold: True
                    color: utils.get_color_from_hex('#a0a0a0')
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size

            # ── 2-column grid ──────────────────────────────────
            GridLayout:
                cols: 2
                size_hint_y: 1

                # ── TOP-LEFT: Appearance ───────────────────────
                BoxLayout:
                    orientation: 'vertical'
                    padding: ['30dp', '24dp', '24dp', '24dp']
                    spacing: '14dp'

                    canvas.before:
                        Color:
                            rgba: utils.get_color_from_hex('#444444')
                        Line:
                            points: [self.right, self.y, self.right, self.top]
                            width: 1
                        Line:
                            points: [self.x, self.y, self.right, self.y]
                            width: 1

                    Label:
                        text: 'APPEARANCE'
                        font_size: '18sp'
                        bold: True
                        color: utils.get_color_from_hex('#6BB562')
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                        size_hint_y: None
                        height: '30dp'

                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '46dp'
                        spacing: '14dp'
                        CheckBox:
                            id: light_mode_cb
                            group: 'theme'
                            size_hint: (None, None)
                            size: ('30dp', '30dp')
                            pos_hint: {'center_y': 0.5}
                            color: utils.get_color_from_hex('#6BB562')
                            on_active:
                                if self.active: root.set_theme('light')
                        Label:
                            text: 'Light Mode'
                            font_size: '22sp'
                            color: utils.get_color_from_hex('#e8e8e8')
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size

                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '46dp'
                        spacing: '14dp'
                        CheckBox:
                            id: dark_mode_cb
                            group: 'theme'
                            active: True
                            size_hint: (None, None)
                            size: ('30dp', '30dp')
                            pos_hint: {'center_y': 0.5}
                            color: utils.get_color_from_hex('#6BB562')
                            on_active:
                                if self.active: root.set_theme('dark')
                        Label:
                            text: 'Dark Mode'
                            font_size: '22sp'
                            color: utils.get_color_from_hex('#e8e8e8')
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size

                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '50dp'
                        spacing: '14dp'
                        Label:
                            text: 'Font Size'
                            font_size: '22sp'
                            color: utils.get_color_from_hex('#e8e8e8')
                            size_hint_x: None
                            width: '160dp'
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size
                        Spinner:
                            id: font_spinner
                            text: 'Medium'
                            values: ['Small', 'Medium', 'Large']
                            size_hint_x: None
                            width: '180dp'
                            background_normal: ''
                            background_color: utils.get_color_from_hex('#3e3e3e')
                            color: utils.get_color_from_hex('#e8e8e8')
                            font_size: '20sp'
                            option_cls: 'SettingsSpinnerOption'
                            on_text: root.set_font_size(self.text)

                    Widget:

                # ── TOP-RIGHT: Notifications ───────────────────
                BoxLayout:
                    orientation: 'vertical'
                    padding: ['30dp', '24dp', '24dp', '24dp']
                    spacing: '20dp'

                    canvas.before:
                        Color:
                            rgba: utils.get_color_from_hex('#444444')
                        Line:
                            points: [self.x, self.y, self.right, self.y]
                            width: 1

                    Label:
                        text: 'NOTIFICATIONS'
                        font_size: '18sp'
                        bold: True
                        color: utils.get_color_from_hex('#6BB562')
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                        size_hint_y: None
                        height: '30dp'

                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '50dp'
                        Label:
                            text: 'Budget Alerts'
                            font_size: '22sp'
                            color: utils.get_color_from_hex('#e8e8e8')
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size
                        Switch:
                            id: budget_toggle
                            active: True
                            size_hint: (None, None)
                            size: ('80dp', '40dp')
                            pos_hint: {'center_y': 0.5}
                            on_active: root.toggle_budget_alerts(self.active)

                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '50dp'
                        Label:
                            text: 'Bill Reminders'
                            font_size: '22sp'
                            color: utils.get_color_from_hex('#e8e8e8')
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size
                        Switch:
                            id: bill_toggle
                            active: False
                            size_hint: (None, None)
                            size: ('80dp', '40dp')
                            pos_hint: {'center_y': 0.5}
                            on_active: root.toggle_bill_reminders(self.active)

                    Widget:

                # ── BOTTOM-LEFT: Data Management ───────────────
                BoxLayout:
                    orientation: 'vertical'
                    padding: ['30dp', '24dp', '24dp', '24dp']
                    spacing: '14dp'

                    canvas.before:
                        Color:
                            rgba: utils.get_color_from_hex('#444444')
                        Line:
                            points: [self.right, self.y, self.right, self.top]
                            width: 1

                    Label:
                        text: 'DATA MANAGEMENT'
                        font_size: '18sp'
                        bold: True
                        color: utils.get_color_from_hex('#6BB562')
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                        size_hint_y: None
                        height: '30dp'

                    Button:
                        text: 'Clear Data'
                        font_size: '20sp'
                        size_hint: (None, None)
                        size: ('220dp', '54dp')
                        background_normal: ''
                        background_color: (0, 0, 0, 0)
                        color: utils.get_color_from_hex('#6BB562')
                        on_release: root.clear_data()
                        canvas.before:
                            Color:
                                rgba: utils.get_color_from_hex('#3a6b3a') if self.state == 'down' else (0, 0, 0, 0)
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [27]
                            Color:
                                rgba: utils.get_color_from_hex('#6BB562')
                            Line:
                                rounded_rectangle: [self.x, self.y, self.width, self.height, 27]
                                width: 1.4

                    Button:
                        text: 'Reset Defaults'
                        font_size: '20sp'
                        size_hint: (None, None)
                        size: ('220dp', '54dp')
                        background_normal: ''
                        background_color: (0, 0, 0, 0)
                        color: utils.get_color_from_hex('#6BB562')
                        on_release: root.reset_defaults()
                        canvas.before:
                            Color:
                                rgba: utils.get_color_from_hex('#3a6b3a') if self.state == 'down' else (0, 0, 0, 0)
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [27]
                            Color:
                                rgba: utils.get_color_from_hex('#6BB562')
                            Line:
                                rounded_rectangle: [self.x, self.y, self.width, self.height, 27]
                                width: 1.4

                    Button:
                        text: 'Delete Account'
                        font_size: '20sp'
                        size_hint: (None, None)
                        size: ('220dp', '54dp')
                        background_normal: ''
                        background_color: (0, 0, 0, 0)
                        color: utils.get_color_from_hex('#d9534f')
                        on_release: root.delete_account()
                        canvas.before:
                            Color:
                                rgba: utils.get_color_from_hex('#6b2020') if self.state == 'down' else (0, 0, 0, 0)
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [27]
                            Color:
                                rgba: utils.get_color_from_hex('#d9534f')
                            Line:
                                rounded_rectangle: [self.x, self.y, self.width, self.height, 27]
                                width: 1.4

                    Widget:

                # ── BOTTOM-RIGHT: Security ─────────────────────
                BoxLayout:
                    orientation: 'vertical'
                    padding: ['30dp', '24dp', '24dp', '24dp']
                    spacing: '14dp'

                    Label:
                        text: 'SECURITY'
                        font_size: '18sp'
                        bold: True
                        color: utils.get_color_from_hex('#6BB562')
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                        size_hint_y: None
                        height: '30dp'

                    Button:
                        text: 'Change Password    \u2192'
                        font_size: '22sp'
                        size_hint_y: None
                        height: '64dp'
                        background_normal: ''
                        background_color: (0, 0, 0, 0)
                        color: utils.get_color_from_hex('#e8e8e8')
                        halign: 'left'
                        text_size: self.width - 20, self.height
                        padding_x: '14dp'
                        on_release: root.open_change_password()
                        canvas.before:
                            Color:
                                rgba: utils.get_color_from_hex('#4a4a4a') if self.state == 'down' else utils.get_color_from_hex('#3e3e3e')
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [10]
                            Color:
                                rgba: utils.get_color_from_hex('#555555')
                            Line:
                                rounded_rectangle: [self.x, self.y, self.width, self.height, 10]
                                width: 1

                    Widget:


# ── Spinner option styling ──────────────────────────────────────
<SettingsSpinnerOption@SpinnerOption>:
    background_normal: ''
    background_color: utils.get_color_from_hex('#3e3e3e')
    color: utils.get_color_from_hex('#e8e8e8')
    font_size: '20sp'
    height: '50dp'
    size_hint_y: None
