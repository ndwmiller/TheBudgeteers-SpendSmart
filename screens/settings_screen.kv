#:import utils kivy.utils

<SettingsScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: [118, 40, 118, 40]

        # ── Settings header label ──────────────────────────────
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(40)
            spacing: dp(10)

            Image:
                source: app.base_path + '/resources/Images/settings_icon.png'
                size_hint: None, None
                size: dp(26), dp(26)
                pos_hint: {'center_y': 0.5}
                allow_stretch: True
                keep_ratio: True

            Label:
                text: "Settings"
                font_size: '22sp'
                bold: True
                color: utils.get_color_from_hex('#656565')
                halign: 'left'
                valign: 'middle'
                text_size: self.size

                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex('#D7D7D7')
                    Rectangle:
                        pos: self.pos
                        size: self.size

                canvas.after:
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)

            Widget:

        Widget:
            size_hint_y: None
            height: dp(16)

        # ── 2×2 panel grid ─────────────────────────────────────
        GridLayout:
            cols: 2
            spacing: 0

            # ── TOP-LEFT: Appearance ───────────────────────────
            BoxLayout:
                orientation: 'vertical'
                padding: [dp(20), dp(15), dp(20), dp(15)]
                spacing: dp(12)

                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex('#D7D7D7')
                    Rectangle:
                        pos: self.pos
                        size: self.size

                canvas.after:
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)

                # Section title
                Label:
                    markup: True
                    text: "[u]Appearance[/u]"
                    font_size: '20sp'
                    color: utils.get_color_from_hex('#6BB562')
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_y: None
                    height: dp(30)

                # Light Mode row
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: dp(40)
                    spacing: dp(10)

                    CheckBox:
                        id: light_mode_cb
                        group: 'theme'
                        size_hint: None, None
                        size: dp(26), dp(26)
                        pos_hint: {'center_y': 0.5}
                        color: utils.get_color_from_hex('#6BB562')
                        on_active: if self.active: root.set_theme('light')

                    Label:
                        text: "Light Mode"
                        font_size: '20sp'
                        color: utils.get_color_from_hex('#6BB562')
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size

                # Dark Mode row
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: dp(40)
                    spacing: dp(10)

                    CheckBox:
                        id: dark_mode_cb
                        group: 'theme'
                        active: True
                        size_hint: None, None
                        size: dp(26), dp(26)
                        pos_hint: {'center_y': 0.5}
                        color: utils.get_color_from_hex('#6BB562')
                        on_active: if self.active: root.set_theme('dark')

                    Label:
                        text: "Dark Mode"
                        font_size: '20sp'
                        color: utils.get_color_from_hex('#6BB562')
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size

                # Font size row
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: dp(40)
                    spacing: dp(10)

                    Label:
                        text: "Font Size"
                        font_size: '20sp'
                        color: utils.get_color_from_hex('#6BB562')
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                        size_hint_x: None
                        width: dp(130)

                    Spinner:
                        id: font_spinner
                        text: 'Medium'
                        values: ['Small', 'Medium', 'Large']
                        size_hint: None, None
                        size: dp(160), dp(34)
                        pos_hint: {'center_y': 0.5}
                        background_normal: ''
                        background_color: utils.get_color_from_hex('#ffffff')
                        color: utils.get_color_from_hex('#656565')
                        font_size: '18sp'
                        option_cls: 'SettingsSpinnerOption'
                        on_text: root.set_font_size(self.text)

                        canvas.after:
                            Color:
                                rgba: utils.get_color_from_hex('#6BB562')
                            Line:
                                width: 1.2
                                rectangle: (self.x, self.y, self.width, self.height)

                Widget:

            # ── TOP-RIGHT: Notifications ───────────────────────
            BoxLayout:
                orientation: 'vertical'
                padding: [dp(20), dp(15), dp(20), dp(15)]
                spacing: dp(16)

                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex('#D7D7D7')
                    Rectangle:
                        pos: self.pos
                        size: self.size

                canvas.after:
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)

                # Section title
                Label:
                    markup: True
                    text: "[u]Notifications[/u]"
                    font_size: '20sp'
                    color: utils.get_color_from_hex('#6BB562')
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_y: None
                    height: dp(30)

                # Budget Alerts row
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: dp(44)

                    Label:
                        text: "Budget Alerts"
                        font_size: '20sp'
                        color: utils.get_color_from_hex('#6BB562')
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size

                    Switch:
                        id: budget_toggle
                        active: True
                        size_hint: None, None
                        size: dp(72), dp(36)
                        pos_hint: {'center_y': 0.5}
                        on_active: root.toggle_budget_alerts(self.active)

                # Bill Reminders row
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: dp(44)

                    Label:
                        text: "Bill Reminders"
                        font_size: '20sp'
                        color: utils.get_color_from_hex('#6BB562')
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size

                    Switch:
                        id: bill_toggle
                        active: False
                        size_hint: None, None
                        size: dp(72), dp(36)
                        pos_hint: {'center_y': 0.5}
                        on_active: root.toggle_bill_reminders(self.active)

                Widget:

            # ── BOTTOM-LEFT: Data Management ───────────────────
            BoxLayout:
                orientation: 'vertical'
                padding: [dp(20), dp(15), dp(20), dp(15)]
                spacing: dp(14)

                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex('#D7D7D7')
                    Rectangle:
                        pos: self.pos
                        size: self.size

                canvas.after:
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)

                # Section title
                Label:
                    markup: True
                    text: "[u]Data Management[/u]"
                    font_size: '20sp'
                    color: utils.get_color_from_hex('#6BB562')
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_y: None
                    height: dp(30)

                # Clear Data button
                Button:
                    text: "Clear Data"
                    font_size: '18sp'
                    size_hint: None, None
                    size: dp(200), dp(34)
                    background_normal: ''
                    background_down: ''
                    background_color: utils.get_color_from_hex('#D7D7D7') if self.state == 'down' else utils.get_color_from_hex('#ffffff')
                    color: utils.get_color_from_hex('#6BB562')
                    text_size: self.size
                    halign: 'center'
                    valign: 'middle'
                    on_release: root.clear_data()

                    canvas.after:
                        Color:
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: dp(1)
                            rounded_rectangle: (self.x, self.y, self.width, self.height, dp(15))

                # Reset Defaults button
                Button:
                    text: "Reset Defaults"
                    font_size: '18sp'
                    size_hint: None, None
                    size: dp(200), dp(34)
                    background_normal: ''
                    background_down: ''
                    background_color: utils.get_color_from_hex('#D7D7D7') if self.state == 'down' else utils.get_color_from_hex('#ffffff')
                    color: utils.get_color_from_hex('#6BB562')
                    text_size: self.size
                    halign: 'center'
                    valign: 'middle'
                    on_release: root.reset_defaults()

                    canvas.after:
                        Color:
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: dp(1)
                            rounded_rectangle: (self.x, self.y, self.width, self.height, dp(15))

                # Delete Account button  (red outline)
                Button:
                    text: "Delete Account"
                    font_size: '18sp'
                    size_hint: None, None
                    size: dp(200), dp(34)
                    background_normal: ''
                    background_down: ''
                    background_color: utils.get_color_from_hex('#f5b8b8') if self.state == 'down' else utils.get_color_from_hex('#ffffff')
                    color: utils.get_color_from_hex('#d9534f')
                    text_size: self.size
                    halign: 'center'
                    valign: 'middle'
                    on_release: root.delete_account()

                    canvas.after:
                        Color:
                            rgba: utils.get_color_from_hex('#d9534f')
                        Line:
                            width: dp(1)
                            rounded_rectangle: (self.x, self.y, self.width, self.height, dp(15))

                Widget:

            # ── BOTTOM-RIGHT: Security ─────────────────────────
            BoxLayout:
                orientation: 'vertical'
                padding: [dp(20), dp(15), dp(20), dp(15)]
                spacing: dp(14)

                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex('#D7D7D7')
                    Rectangle:
                        pos: self.pos
                        size: self.size

                canvas.after:
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)

                # Section title
                Label:
                    markup: True
                    text: "[u]Security[/u]"
                    font_size: '20sp'
                    color: utils.get_color_from_hex('#6BB562')
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_y: None
                    height: dp(30)

                # Change Password button
                Button:
                    text: "Change Password   \u2192"
                    font_size: '18sp'
                    size_hint: 1, None
                    height: dp(34)
                    background_normal: ''
                    background_down: ''
                    background_color: utils.get_color_from_hex('#D7D7D7') if self.state == 'down' else utils.get_color_from_hex('#ffffff')
                    color: utils.get_color_from_hex('#656565')
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.width - dp(16), self.height
                    padding_x: dp(10)
                    on_release: root.open_change_password()

                    canvas.after:
                        Color:
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: dp(1)
                            rectangle: (self.x, self.y, self.width, self.height)

                Widget:


# ── Spinner option ──────────────────────────────────────────────
<SettingsSpinnerOption@SpinnerOption>:
    background_normal: ''
    background_color: utils.get_color_from_hex('#ffffff')
    color: utils.get_color_from_hex('#656565')
    font_size: '18sp'
    height: dp(40)
    size_hint_y: None
