#:import utils kivy.utils
#:import dp kivy.metrics.dp

<BudgetEditValueInput@TextInput>:
    size_hint: None, None
    size: dp(300), dp(70)
    font_size: '30sp'
    halign: 'center'
    multiline: False
    background_normal: ''
    background_active: ''
    background_color: 1, 1, 1, 1
    foreground_color: utils.get_color_from_hex('#519D4A')
    cursor_color: utils.get_color_from_hex('#519D4A')
    padding: dp(12), dp(16)

<BudgetEditCellInput@TextInput>:
    size_hint: None, None
    size: dp(160), dp(22)
    font_size: '18sp'
    halign: 'center'
    multiline: False
    background_normal: ''
    background_active: ''
    background_color: 1, 1, 1, 1
    foreground_color: utils.get_color_from_hex('#519D4A')
    cursor_color: utils.get_color_from_hex('#519D4A')
    padding: dp(6), dp(2)

<BudgetEditNameInput@TextInput>:
    size_hint: None, None
    size: dp(250), dp(22)
    font_size: '16sp'
    halign: 'left'
    multiline: False
    background_normal: ''
    background_active: ''
    background_color: 1, 1, 1, 1
    foreground_color: utils.get_color_from_hex('#519D4A')
    cursor_color: utils.get_color_from_hex('#519D4A')
    padding: dp(6), dp(2)

<BudgetEditScreen>:
    FloatLayout:
        FloatLayout:
            size_hint: None, None
            width: min(root.width * 0.78, dp(860))
            height: dp(125)
            pos_hint: {'center_x': 0.5, 'top': 0.76}

            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex('#D7D7D7')
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: utils.get_color_from_hex('#6BB562')
                Line:
                    width: 1.4
                    rectangle: (self.x, self.y, self.width, self.height)
                Line:
                    width: 1.2
                    points: (self.center_x, self.y, self.center_x, self.top)

            Label:
                text: 'Current Budget'
                size_hint: None, None
                size: dp(140), dp(28)
                pos_hint: {'center_x': 0.25, 'top': 1.14}
                color: utils.get_color_from_hex('#656565')
                font_size: '14sp'
                bold: True
                halign: 'center'
                valign: 'middle'
                text_size: self.size
                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex('#D7D7D7')
                    Rectangle:
                        pos: self.pos
                        size: self.size
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)

            BudgetEditValueInput:
                id: current_input
                text: root.current_budget
                pos_hint: {'center_x': 0.25, 'center_y': 0.47}

            Label:
                text: 'Monthly Budget'
                size_hint: None, None
                size: dp(140), dp(28)
                pos_hint: {'center_x': 0.75, 'top': 1.14}
                color: utils.get_color_from_hex('#656565')
                font_size: '14sp'
                bold: True
                halign: 'center'
                valign: 'middle'
                text_size: self.size
                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex('#D7D7D7')
                    Rectangle:
                        pos: self.pos
                        size: self.size
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)

            BudgetEditValueInput:
                id: monthly_input
                text: root.monthly_budget
                pos_hint: {'center_x': 0.75, 'center_y': 0.47}

        FloatLayout:
            size_hint: None, None
            width: min(root.width * 0.78, dp(860))
            height: dp(250)
            pos_hint: {'center_x': 0.5, 'top': 0.54}

            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex('#D7D7D7')
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: utils.get_color_from_hex('#6BB562')
                Line:
                    width: 1.4
                    rectangle: (self.x, self.y, self.width, self.height)

            Label:
                text: 'Categories'
                size_hint: None, None
                size: dp(130), dp(28)
                pos_hint: {'center_x': 0.5, 'y': 1}
                color: utils.get_color_from_hex('#656565')
                font_size: '14sp'
                bold: True
                halign: 'center'
                valign: 'middle'
                text_size: self.size
                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex('#D7D7D7')
                    Rectangle:
                        pos: self.pos
                        size: self.size
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)

            BoxLayout:
                orientation: 'horizontal'
                size_hint: None, None
                size: dp(480), dp(26)
                pos_hint: {'center_x': 0.5, 'top': 0.90}
                spacing: dp(10)

                Label:
                    text: 'Categories'
                    color: utils.get_color_from_hex('#519D4A')
                    font_size: '17sp'
                    bold: True
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_x: 0.58

                Label:
                    text: 'Percent'
                    color: utils.get_color_from_hex('#519D4A')
                    font_size: '16sp'
                    bold: True
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_x: 0.42

            ScrollView:
                size_hint: None, None
                size: dp(480), dp(145)
                pos_hint: {'center_x': 0.5, 'top': 0.77}
                do_scroll_x: False
                bar_width: dp(6)

                GridLayout:
                    id: categories_grid
                    cols: 1
                    spacing: dp(8)
                    size_hint_x: 1
                    size_hint_y: None
                    height: self.minimum_height

        Button:
            text: 'Add Category'
            size_hint: None, None
            size: dp(95), dp(24)
            pos_hint: {'center_x': 0.5, 'y': 0.12}
            background_normal: ''
            background_down: ''
            background_color: utils.get_color_from_hex('#DAFFC8')
            color: utils.get_color_from_hex('#519D4A')
            font_size: '14sp'
            bold: True
            on_release: root.add_category()
            canvas.after:
                Color:
                    rgba: utils.get_color_from_hex('#6BB562')
                Line:
                    width: 1.2
                    rectangle: (self.x, self.y, self.width, self.height)

        BoxLayout:
            orientation: 'horizontal'
            size_hint: None, None
            size: dp(220), dp(24)
            pos_hint: {'center_x': 0.5, 'y': 0.06}
            spacing: dp(30)

            Button:
                text: 'Cancel'
                size_hint: None, None
                size: dp(95), dp(24)
                background_normal: ''
                background_down: ''
                background_color: 1, 1, 1, 1
                color: utils.get_color_from_hex('#519D4A')
                font_size: '14sp'
                on_release: root.cancel_edit()
                canvas.after:
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)

            Button:
                text: 'Save'
                size_hint: None, None
                size: dp(95), dp(24)
                background_normal: ''
                background_down: ''
                background_color: utils.get_color_from_hex('#DAFFC8')
                color: utils.get_color_from_hex('#519D4A')
                font_size: '14sp'
                bold: True
                on_release: root.save_edit()
                canvas.after:
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)