#:import utils kivy.utils
#:import dp kivy.metrics.dp

<BudgetEditValueInput@TextInput>:
    size_hint: None, None
    size: dp(300), dp(70)
    font_size: '30sp'
    halign: 'center'
    multiline: False
    background_normal: ''
    background_active: ''
    background_color: 1, 1, 1, 1
    foreground_color: utils.get_color_from_hex('#519D4A')
    cursor_color: utils.get_color_from_hex('#519D4A')
    padding: dp(12), dp(16)
    canvas.after:
        Color:
            rgba: utils.get_color_from_hex('#6BB562')
        Line:
            width: 1.2
            rectangle: (self.x, self.y, self.width, self.height)

<BudgetEditCellInput@TextInput>:
    size_hint: None, None
    size: dp(160), dp(22)
    font_size: '18sp'
    halign: 'center'
    multiline: False
    background_normal: ''
    background_active: ''
    background_color: 1, 1, 1, 1
    foreground_color: utils.get_color_from_hex('#519D4A')
    cursor_color: utils.get_color_from_hex('#519D4A')
    padding: dp(6), dp(2)
    canvas.after:
        Color:
            rgba: utils.get_color_from_hex('#6BB562')
        Line:
            width: 1.2
            rectangle: (self.x, self.y, self.width, self.height)

<BudgetEditNameInput@TextInput>:
    size_hint: None, None
    size: dp(250), dp(22)
    font_size: '16sp'
    halign: 'left'
    multiline: False
    background_normal: ''
    background_active: ''
    background_color: 1, 1, 1, 1
    foreground_color: utils.get_color_from_hex('#519D4A')
    cursor_color: utils.get_color_from_hex('#519D4A')
    padding: dp(6), dp(2)
    canvas.after:
        Color:
            rgba: utils.get_color_from_hex('#6BB562')
        Line:
            width: 1.2
            rectangle: (self.x, self.y, self.width, self.height)

<BudgetEditScreen>:
    FloatLayout:
        FloatLayout:
            size_hint: None, None
            width: min(root.width * 0.78, dp(860))
            height: dp(125)
            pos_hint: {'center_x': 0.5, 'top': 0.79}

            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex('#D7D7D7')
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: utils.get_color_from_hex('#6BB562')
                Line:
                    width: 1.4
                    rectangle: (self.x, self.y, self.width, self.height)
                Line:
                    width: 1.2
                    points: (self.center_x, self.y, self.center_x, self.top)

            Label:
                text: '[u]Current Budget[/u]'
                markup: True
                size_hint: None, None
                size: dp(140), dp(28)
                pos_hint: {'center_x': 0.25, 'top': 1.10}
                color: utils.get_color_from_hex('#656565')
                font_size: '14sp'
                bold: False
                halign: 'center'
                valign: 'middle'
                text_size: self.size
                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex('#D7D7D7')
                    Rectangle:
                        pos: self.pos
                        size: self.size
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)

            BudgetEditValueInput:
                id: current_input
                text: root.current_budget
                pos_hint: {'center_x': 0.25, 'center_y': 0.47}

            Label:
                text: '[u]Monthly Budget[/u]'
                markup: True
                size_hint: None, None
                size: dp(140), dp(28)
                pos_hint: {'center_x': 0.75, 'top': 1.10}
                color: utils.get_color_from_hex('#656565')
                font_size: '14sp'
                bold: False
                halign: 'center'
                valign: 'middle'
                text_size: self.size
                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex('#D7D7D7')
                    Rectangle:
                        pos: self.pos
                        size: self.size
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)

            BudgetEditValueInput:
                id: monthly_input
                text: root.monthly_budget
                pos_hint: {'center_x': 0.75, 'center_y': 0.47}

        Widget:
            size_hint: None, None
            size: min(root.width * 0.78, dp(860)), dp(16)
            pos_hint: {'center_x': 0.5, 'top': 0.62}

        FloatLayout:
            size_hint: None, None
            width: min(root.width * 0.78, dp(860))
            height: dp(290)
            pos_hint: {'center_x': 0.5, 'top': 0.55}

            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex('#D7D7D7')
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: utils.get_color_from_hex('#6BB562')
                Line:
                    width: 1.4
                    rectangle: (self.x, self.y, self.width, self.height)

            Label:
                text: '[u]Categories[/u]'
                markup: True
                size_hint: None, None
                size: dp(130), dp(28)
                pos_hint: {'center_x': 0.5, 'y': 1}
                color: utils.get_color_from_hex('#656565')
                font_size: '14sp'
                bold: False
                halign: 'center'
                valign: 'middle'
                text_size: self.size
                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex('#D7D7D7')
                    Rectangle:
                        pos: self.pos
                        size: self.size
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)

            BoxLayout:
                orientation: 'horizontal'
                size_hint: None, None
                size: dp(502), dp(26)
                pos_hint: {'center_x': 0.5, 'top': 0.91}
                spacing: dp(10)

                Label:
                    text: '[u]Categories[/u]'
                    markup: True
                    color: utils.get_color_from_hex('#519D4A')
                    font_size: '17sp'
                    bold: False
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_x: 0.58

                Label:
                    text: '[u]Percent[/u]'
                    markup: True
                    color: utils.get_color_from_hex('#519D4A')
                    font_size: '16sp'
                    bold: False
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_x: 0.34

                Widget:
                    size_hint_x: None
                    width: dp(22)

            GridLayout:
                id: categories_grid
                cols: 1
                spacing: dp(8)
                size_hint: None, None
                size: dp(502), dp(170)
                pos_hint: {'center_x': 0.5, 'top': 0.80}

        Button:
            text: 'Add Category'
            size_hint: None, None
            size: dp(95), dp(24)
            pos_hint: {'center_x': 0.5, 'y': 0.12}
            background_normal: ''
            background_down: ''
            background_color: utils.get_color_from_hex('#DAFFC8')
            color: utils.get_color_from_hex('#519D4A')
            font_size: '14sp'
            bold: False
            on_release: root.add_category()
            canvas.after:
                Color:
                    rgba: utils.get_color_from_hex('#6BB562')
                Line:
                    width: 1.2
                    rectangle: (self.x, self.y, self.width, self.height)

        BoxLayout:
            orientation: 'horizontal'
            size_hint: None, None
            size: dp(220), dp(24)
            pos_hint: {'center_x': 0.5, 'y': 0.06}
            spacing: dp(30)

            Button:
                text: 'Cancel'
                size_hint: None, None
                size: dp(95), dp(24)
                background_normal: ''
                background_down: ''
                background_color: 1, 1, 1, 1
                color: utils.get_color_from_hex('#519D4A')
                font_size: '14sp'
                on_release: root.cancel_edit()
                canvas.after:
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)

            Button:
                text: 'Save'
                size_hint: None, None
                size: dp(95), dp(24)
                background_normal: ''
                background_down: ''
                background_color: utils.get_color_from_hex('#DAFFC8')
                color: utils.get_color_from_hex('#519D4A')
                font_size: '14sp'
                bold: False
                on_release: root.save_edit()
                canvas.after:
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)