#:import utils kivy.utils
#:import dp kivy.metrics.dp

<BudgetEditValueInput@TextInput>:
    size_hint: None, None
    size: dp(255), dp(64)
    font_size: '30sp'
    halign: 'center'
    multiline: False
    background_normal: ''
    background_active: ''
    background_color: 1, 1, 1, 1
    foreground_color: utils.get_color_from_hex('#519D4A')
    cursor_color: utils.get_color_from_hex('#519D4A')
    padding: dp(12), dp(16)
    canvas.after:
        Color:
            rgba: utils.get_color_from_hex('#6BB562')
        Line:
            width: 1.2
            rectangle: (self.x, self.y, self.width, self.height)

<BudgetEditCellInput@TextInput>:
    size_hint: None, None
    size: dp(140), dp(22)
    font_size: '18sp'
    halign: 'center'
    multiline: False
    background_normal: ''
    background_active: ''
    background_color: 1, 1, 1, 1
    foreground_color: utils.get_color_from_hex('#519D4A')
    cursor_color: utils.get_color_from_hex('#519D4A')
    padding: dp(6), dp(2)
    canvas.after:
        Color:
            rgba: utils.get_color_from_hex('#6BB562')
        Line:
            width: 1.2
            rectangle: (self.x, self.y, self.width, self.height)

<BudgetEditNameInput@TextInput>:
    size_hint: None, None
    size: dp(140), dp(22)
    font_size: '16sp'
    halign: 'center'
    multiline: False
    background_normal: ''
    background_active: ''
    background_color: 1, 1, 1, 1
    foreground_color: utils.get_color_from_hex('#519D4A')
    cursor_color: utils.get_color_from_hex('#519D4A')
    padding: dp(6), dp(2)
    canvas.after:
        Color:
            rgba: utils.get_color_from_hex('#6BB562')
        Line:
            width: 1.2
            rectangle: (self.x, self.y, self.width, self.height)

<BudgetEditCategoryRow@BoxLayout>:
    orientation: 'horizontal'
    size_hint: None, None
    height: dp(26)
    width: dp(350)
    spacing: dp(8)

    BudgetEditNameInput:
        text: root.cat_name
        on_text: root.cat_name = self.text

    Widget:
        size_hint: None, None
        size: dp(22), dp(26)

    BudgetEditCellInput:
        text: root.cat_percent
        on_text: root.cat_percent = self.text

    Button:
        size_hint: None, None
        size: dp(22), dp(22)
        pos_hint: {'center_y': 0.5}
        background_normal: app.base_path + '/resources/Images/trash_icon.png'
        background_down: app.base_path + '/resources/Images/trash_icon.png'
        background_color: 1, 1, 1, 1
        border: 0, 0, 0, 0
        on_release: root.on_delete()

<BudgetEditScreen>:
    FloatLayout:
        canvas.before:
            Color:
                rgba: utils.get_color_from_hex('#4D4D4D')
            Rectangle:
                pos: self.pos
                size: self.size

        FloatLayout:
            size_hint: None, None
            width: min(root.width * 0.62, dp(660))
            height: dp(125)
            pos_hint: {'center_x': 0.5, 'top': 0.84}

            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex('#D7D7D7')
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: utils.get_color_from_hex('#6BB562')
                Line:
                    width: 1.4
                    rectangle: (self.x, self.y, self.width, self.height)

            Label:
                text: 'Monthly Budget'
                size_hint: None, None
                size: dp(180), dp(30)
                pos_hint: {'center_x': 0.5, 'top': 1.24}
                color: utils.get_color_from_hex('#656565')
                font_size: '20sp'
                bold: False
                halign: 'center'
                valign: 'middle'
                text_size: self.size
                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex('#D7D7D7')
                    Rectangle:
                        pos: self.pos
                        size: self.size
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)

            BoxLayout:
                orientation: 'horizontal'
                size_hint: None, None
                size: dp(255), dp(64)
                pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                spacing: dp(4)

                Label:
                    text: '$'
                    color: utils.get_color_from_hex('#519D4A')
                    font_size: '30sp'
                    bold: True
                    size_hint_x: None
                    width: dp(28)
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size

                BudgetEditValueInput:
                    id: monthly_input
                    text: root.monthly_budget
                    size_hint: 1, 1

        Widget:
            size_hint: None, None
            size: min(root.width * 0.62, dp(660)), dp(16)
            pos_hint: {'center_x': 0.5, 'top': 0.67}

        FloatLayout:
            size_hint: None, None
            width: min(root.width * 0.62, dp(660))
            height: dp(350)
            pos_hint: {'center_x': 0.5, 'top': 0.57}

            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex('#D7D7D7')
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: utils.get_color_from_hex('#6BB562')
                Line:
                    width: 1.4
                    rectangle: (self.x, self.y, self.width, self.height)

            Label:
                text: 'Categories'
                size_hint: None, None
                size: dp(150), dp(30)
                pos_hint: {'center_x': 0.5, 'y': 1}
                color: utils.get_color_from_hex('#656565')
                font_size: '20sp'
                bold: False
                halign: 'center'
                valign: 'middle'
                text_size: self.size
                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex('#D7D7D7')
                    Rectangle:
                        pos: self.pos
                        size: self.size
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)

            Label:
                text: "You have no categories yet. Add one!"
                opacity: 0 if root.has_categories else 1
                color: utils.get_color_from_hex('#519D4A')
                font_size: '16sp'
                halign: 'center'
                valign: 'middle'
                text_size: self.size
                pos_hint: {'center_x': 0.5, 'center_y': 0.55}
                size_hint: None, None
                size: dp(330), dp(40)

            BoxLayout:
                orientation: 'horizontal'
                opacity: 1 if root.has_categories else 0
                size_hint: None, None
                size: dp(350), dp(26)
                pos_hint: {'center_x': 0.52, 'top': 0.90}
                spacing: dp(8)

                Label:
                    text: '[u]Name[/u]'
                    markup: True
                    color: utils.get_color_from_hex('#519D4A')
                    font_size: '16sp'
                    bold: False
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_x: None
                    width: dp(140)

                Widget:
                    size_hint_x: None
                    width: dp(22)

                Label:
                    text: '[u]Percent[/u]'
                    markup: True
                    color: utils.get_color_from_hex('#519D4A')
                    font_size: '16sp'
                    bold: False
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_x: None
                    width: dp(140)

                Widget:
                    size_hint_x: None
                    width: dp(22)

            GridLayout:
                id: categories_grid
                cols: 1
                spacing: dp(8)
                size_hint: None, None
                size: dp(350), dp(170)
                pos_hint: {'center_x': 0.52, 'top': 0.80}

            BoxLayout:
                orientation: 'vertical'
                size_hint: None, None
                size: dp(300), dp(84)
                pos_hint: {'center_x': 0.5, 'y': 0.03}
                spacing: dp(6)

                AnchorLayout:
                    anchor_x: 'center'
                    size_hint_y: None
                    height: dp(24)

                    Button:
                        text: 'Add Category'
                        size_hint: None, None
                        size: dp(95), dp(24)
                        background_normal: ''
                        background_down: ''
                        background_color: utils.get_color_from_hex('#DAFFC8')
                        color: utils.get_color_from_hex('#519D4A')
                        font_size: '14sp'
                        bold: False
                        on_release: root.add_category()
                        canvas.after:
                            Color:
                                rgba: utils.get_color_from_hex('#6BB562')
                            Line:
                                width: 1.2
                                rectangle: (self.x, self.y, self.width, self.height)

                Label:
                    id: error_label
                    text: ''
                    opacity: 1 if self.text else 0
                    color: utils.get_color_from_hex('#e44949')
                    font_size: '14sp'
                    size_hint_y: None
                    height: dp(24)
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size

                AnchorLayout:
                    anchor_x: 'center'
                    size_hint_y: None
                    height: dp(24)

                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint: None, None
                        size: dp(220), dp(24)
                        spacing: dp(30)

                        Button:
                            text: 'Cancel'
                            size_hint: None, None
                            size: dp(95), dp(24)
                            background_normal: ''
                            background_down: ''
                            background_color: (1, 1, 1, 1) if app.theme == 'light' else (0.24, 0.24, 0.24, 1) if self.state == 'down' else (0.302, 0.302, 0.302, 1)
                            color: utils.get_color_from_hex('#519D4A')
                            font_size: '14sp'
                            on_release: root.cancel_edit()
                            canvas.after:
                                Color:
                                    rgba: utils.get_color_from_hex('#6BB562')
                                Line:
                                    width: 1.2
                                    rectangle: (self.x, self.y, self.width, self.height)

                        Button:
                            text: 'Save'
                            size_hint: None, None
                            size: dp(95), dp(24)
                            background_normal: ''
                            background_down: ''
                            background_color: utils.get_color_from_hex('#DAFFC8')
                            color: utils.get_color_from_hex('#519D4A')
                            font_size: '14sp'
                            bold: False
                            on_release: root.save_edit()
                            canvas.after:
                                Color:
                                    rgba: utils.get_color_from_hex('#6BB562')
                                Line:
                                    width: 1.2
                                    rectangle: (self.x, self.y, self.width, self.height)