#:import utils kivy.utils
#:import dp kivy.metrics.dp

<TransactionRow>:
    size_hint_y: None
    height: dp(60)
    spacing: 0

    canvas.before:
        Color:
            rgba: utils.get_color_from_hex('#D7D7D7')
        Rectangle:
            pos: self.pos
            size: self.size

    Label:
        text: str(root.row_data[1]) if len(root.row_data) > 1 else ""
        color: utils.get_color_from_hex('#6BB562')
        halign: "center"
        valign: "middle"
        text_size: self.size
        size_hint_x: 1.25

        canvas.after:
            Color:
                rgba: utils.get_color_from_hex('#6BB562')
            Line:
                width: 1.2
                rectangle: (self.x, self.y, self.width, self.height)

    Label:
        text: str(root.row_data[2]) if len(root.row_data) > 2 else ""
        color: utils.get_color_from_hex('#6BB562')
        halign: "center"
        valign: "middle"
        text_size: self.size
        size_hint_x: 1.75

        canvas.after:
            Color:
                rgba: utils.get_color_from_hex('#6BB562')
            Line:
                width: 1.2
                rectangle: (self.x, self.y, self.width, self.height)

    Label:
        text: str(root.row_data[3]) if len(root.row_data) > 3 else ""
        color: utils.get_color_from_hex('#6BB562')
        halign: "center"
        valign: "middle"
        text_size: self.size
        size_hint_x: 1.75

        canvas.after:
            Color:
                rgba: utils.get_color_from_hex('#6BB562')
            Line:
                width: 1.2
                rectangle: (self.x, self.y, self.width, self.height)

    Label:
        text: "$ {:.2f}".format(float(root.row_data[4])) if len(root.row_data) > 4 else ""
        color: utils.get_color_from_hex('#6BB562')
        halign: "center"
        valign: "middle"
        text_size: self.size
        size_hint_x: 1.45

        canvas.after:
            Color:
                rgba: utils.get_color_from_hex('#6BB562')
            Line:
                width: 1.2
                rectangle: (self.x, self.y, self.width, self.height)

    BoxLayout:
        size_hint_x: 0.9
        padding: dp(12), dp(8)

        canvas.before:
            Color:
                rgba: utils.get_color_from_hex('#D7D7D7')
            Rectangle:
                pos: self.pos
                size: self.size
        canvas.after:
            Color:
                rgba: utils.get_color_from_hex('#6BB562')
            Line:
                width: 1.2
                rectangle: (self.x, self.y, self.width, self.height)

        Button:
            text: "Edit"
            background_normal: ""
            background_down: ""
            background_color: utils.get_color_from_hex('#abff80') if self.state == 'down' else utils.get_color_from_hex('#DAFFC8')
            color: utils.get_color_from_hex('#6BB562')

            canvas.after:
                Color:
                    rgba: utils.get_color_from_hex('#6BB562')
                Line:
                    width: 1.2
                    rectangle: (self.x, self.y, self.width, self.height)

            on_release: root.parent_screen.open_edit_popup(root.row_data)

    BoxLayout:
        size_hint_x: 0.9
        padding: dp(12), dp(8)

        canvas.before:
            Color:
                rgba: utils.get_color_from_hex('#D7D7D7')
            Rectangle:
                pos: self.pos
                size: self.size
        canvas.after:
            Color:
                rgba: utils.get_color_from_hex('#6BB562')
            Line:
                width: 1.2
                rectangle: (self.x, self.y, self.width, self.height)

        Button:
            text: "Delete"
            background_normal: ""
            background_down: ""
            background_color: utils.get_color_from_hex('#FFD7D7') if self.state == 'down' else utils.get_color_from_hex('#FAEAEA')
            color: utils.get_color_from_hex('#B85555')

            canvas.after:
                Color:
                    rgba: utils.get_color_from_hex('#B85555')
                Line:
                    width: 1.2
                    rectangle: (self.x, self.y, self.width, self.height)

            on_release: root.parent_screen.delete_row(root.row_data[0])


<TransactionsScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: dp(90), dp(36), dp(90), dp(36)
        spacing: dp(18)

        canvas.before:
            Color:
                rgba: utils.get_color_from_hex('#4D4D4D')
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            orientation: "vertical"
            spacing: 0
            size_hint_y: 1

            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex('#D7D7D7')
                Rectangle:
                    pos: self.pos
                    size: self.size
            canvas.after:
                Color:
                    rgba: utils.get_color_from_hex('#6BB562')
                Line:
                    width: 1.2
                    rectangle: (self.x, self.y, self.width, self.height)

            # ── TOOLBAR ──────────────────────────────────────────────
            BoxLayout:
                size_hint_y: None
                height: dp(84)
                padding: dp(26), dp(18), dp(26), dp(14)
                spacing: dp(16)

                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex('#D7D7D7')
                    Rectangle:
                        pos: self.pos
                        size: self.size
                canvas.after:
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)

                Label:
                    text: "Search"
                    color: utils.get_color_from_hex('#6BB562')
                    size_hint_x: None
                    width: dp(90)
                    halign: "right"
                    valign: "middle"
                    text_size: self.size
                    font_size: "18sp"
                    bold: True

                TextInput:
                    id: search_input
                    hint_text: "..."
                    multiline: False
                    size_hint_x: 1
                    background_normal: ""
                    background_active: ""
                    background_color: 1, 1, 1, 1
                    foreground_color: 0.35, 0.35, 0.35, 1
                    padding: dp(12), dp(10)
                    font_size: "16sp"
                    on_text: root.load_transactions()

                    canvas.after:
                        Color:
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: 1.2
                            rectangle: (self.x, self.y, self.width, self.height)

                Spinner:
                    id: filter_spinner
                    text: "All"
                    values: []
                    size_hint_x: None
                    width: dp(130)
                    background_normal: ""
                    background_down: ""
                    background_color: utils.get_color_from_hex('#ffffff')
                    color: utils.get_color_from_hex('#656565')
                    font_size: "16sp"
                    on_text: root.load_transactions()

                    canvas.after:
                        Color:
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: 1.2
                            rectangle: (self.x, self.y, self.width, self.height)

                Button:
                    text: "Add Transaction"
                    size_hint_x: None
                    width: dp(175)
                    background_normal: ""
                    background_down: ""
                    background_color: utils.get_color_from_hex('#abff80') if self.state == 'down' else utils.get_color_from_hex('#DAFFC8')
                    color: utils.get_color_from_hex('#6BB562')
                    font_size: "16sp"
                    on_release: root.open_add_popup()

                    canvas.after:
                        Color:
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: 1.2
                            rectangle: (self.x, self.y, self.width, self.height)

            # ── HEADER ROW ───────────────────────────────────────────
            BoxLayout:
                size_hint_y: None
                height: dp(52)
                spacing: 0

                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex('#C8E6C2')
                    Rectangle:
                        pos: self.pos
                        size: self.size
                canvas.after:
                    Color:
                        rgba: utils.get_color_from_hex('#6BB562')
                    Line:
                        width: 1.2
                        rectangle: (self.x, self.y, self.width, self.height)

                Label:
                    text: "Date"
                    bold: True
                    font_size: "16sp"
                    color: utils.get_color_from_hex('#6BB562')
                    halign: "center"
                    valign: "middle"
                    text_size: self.size
                    size_hint_x: 1.25

                    canvas.after:
                        Color:
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: 1.2
                            rectangle: (self.x, self.y, self.width, self.height)

                Label:
                    text: "Name"
                    bold: True
                    font_size: "16sp"
                    color: utils.get_color_from_hex('#6BB562')
                    halign: "center"
                    valign: "middle"
                    text_size: self.size
                    size_hint_x: 1.75

                    canvas.after:
                        Color:
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: 1.2
                            rectangle: (self.x, self.y, self.width, self.height)

                Label:
                    text: "Category"
                    bold: True
                    font_size: "16sp"
                    color: utils.get_color_from_hex('#6BB562')
                    halign: "center"
                    valign: "middle"
                    text_size: self.size
                    size_hint_x: 1.75

                    canvas.after:
                        Color:
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: 1.2
                            rectangle: (self.x, self.y, self.width, self.height)

                Label:
                    text: "Amount"
                    bold: True
                    font_size: "16sp"
                    color: utils.get_color_from_hex('#6BB562')
                    halign: "center"
                    valign: "middle"
                    text_size: self.size
                    size_hint_x: 1.45

                    canvas.after:
                        Color:
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: 1.2
                            rectangle: (self.x, self.y, self.width, self.height)

                Label:
                    text: "Edit"
                    bold: True
                    font_size: "16sp"
                    color: utils.get_color_from_hex('#6BB562')
                    halign: "center"
                    valign: "middle"
                    text_size: self.size
                    size_hint_x: 0.9

                    canvas.after:
                        Color:
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: 1.2
                            rectangle: (self.x, self.y, self.width, self.height)

                Label:
                    text: "Delete"
                    bold: True
                    font_size: "16sp"
                    color: utils.get_color_from_hex('#6BB562')
                    halign: "center"
                    valign: "middle"
                    text_size: self.size
                    size_hint_x: 0.9

                    canvas.after:
                        Color:
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: 1.2
                            rectangle: (self.x, self.y, self.width, self.height)

            # ── SCROLL AREA ──────────────────────────────────────────
            ScrollView:
                do_scroll_x: False
                do_scroll_y: True
                bar_width: dp(8)

                BoxLayout:
                    id: transactions_rows
                    orientation: "vertical"
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: 0