#:import utils kivy.utils

<ResetAppData>:
    size_hint: None, None
    size: dp(400), dp(300)
    auto_dismiss: True
    # Dark overlay — same as add_bill.kv
    background_color: [0, 0, 0, 0.2]

    BoxLayout:
        orientation: 'vertical'

        # ── Header label ───────────────────────────────────────
        Label:
            pos_hint: {'center_x': .5, 'center_y': .5}
            text: "Reset App Data"
            font_size: '20sp'
            color: utils.get_color_from_hex('#656565')
            halign: 'center'
            valign: 'middle'
            text_size: self.size
            size_hint: None, None
            width: dp(270)
            height: dp(35)

            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex('#D7D7D7')
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: (dp(15), dp(15), 0, 0)

            canvas.after:
                Color:
                    rgba: utils.get_color_from_hex('#6BB562')
                Line:
                    width: dp(1)
                    rounded_rectangle: (self.x, self.y, self.width, self.height, dp(15), dp(15), 0, 0)

        # ── Body container ─────────────────────────────────────
        BoxLayout:
            orientation: 'vertical'
            padding: dp(20)
            spacing: dp(15)

            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex('#D7D7D7')
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(15)]

            canvas.after:
                Color:
                    rgba: utils.get_color_from_hex('#6BB562')
                Line:
                    width: dp(1)
                    rounded_rectangle: (self.x, self.y, self.width, self.height, dp(15))

            # Confirmation message
            Label:
                text: "Are you sure you want to reset\nall app data? This cannot be undone."
                font_size: '18sp'
                color: utils.get_color_from_hex('#6BB562')
                halign: 'center'
                valign: 'middle'
                text_size: self.size

            # Error label
            Label:
                id: error_label
                text: ""
                color: utils.get_color_from_hex('#e44949')
                font_size: '14sp'
                size_hint_y: None
                height: dp(20) if self.text else 0
                halign: 'center'

            Widget:
                size_hint_y: 0.1

            # ── Cancel / Confirm buttons ────────────────────────
            BoxLayout:
                size_hint_y: None
                height: dp(50)
                spacing: dp(10)
                padding: [0, dp(10), 0, 0]

                # Cancel button
                Button:
                    pos_hint: {'center_x': .5, 'center_y': .5}
                    background_normal: ''
                    background_down: ''
                    background_color: utils.get_color_from_hex('#d7d7d7') if self.state == 'down' else utils.get_color_from_hex('#ffffff')
                    color: utils.get_color_from_hex('#6BB562')
                    font_size: '18sp'
                    size_hint_y: None
                    height: dp(30)
                    text_size: self.size
                    halign: 'center'
                    valign: 'middle'
                    text: "Cancel"
                    on_release: root.dismiss()

                    canvas.after:
                        Color:
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: dp(1)
                            rectangle: (self.x, self.y, self.width, self.height)

                # Confirm button
                Button:
                    pos_hint: {'center_x': .5, 'center_y': .5}
                    background_normal: ''
                    background_down: ''
                    background_color: utils.get_color_from_hex('#abff80') if self.state == 'down' else utils.get_color_from_hex('#DAFFC8')
                    color: utils.get_color_from_hex('#6BB562')
                    font_size: '18sp'
                    size_hint_y: None
                    height: dp(30)
                    text_size: self.size
                    halign: 'center'
                    valign: 'middle'
                    text: "Confirm"
                    on_release: root.submit_data()

                    canvas.after:
                        Color:
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: dp(1)
                            rectangle: (self.x, self.y, self.width, self.height)
