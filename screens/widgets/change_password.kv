#:import utils kivy.utils

# ─────────────────────────────────────────────────────────────────
#  ChangePassword modal
#  Author: Sakhi Hussain
# ─────────────────────────────────────────────────────────────────

<ChangePassword>:
    size_hint: (None, None)
    size: ('700dp', '540dp')
    auto_dismiss: True
    background_color: [0, 0, 0, 0.6]

    BoxLayout:
        orientation: 'vertical'
        size_hint: (1, 1)
        spacing: 0

        canvas.before:
            Color:
                rgba: utils.get_color_from_hex('#2a2a2a')
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [16]
            Color:
                rgba: utils.get_color_from_hex('#444444')
            Line:
                rounded_rectangle: [self.x, self.y, self.width, self.height, 16]
                width: 1.2

        # ── Header ─────────────────────────────────────────────
        BoxLayout:
            size_hint_y: None
            height: '70dp'
            padding: ['20dp', '0dp']

            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex('#333333')
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [16, 16, 0, 0]
                Color:
                    rgba: utils.get_color_from_hex('#444444')
                Line:
                    points: [self.x, self.y, self.x + self.width, self.y]
                    width: 1

            Label:
                text: 'Change Password'
                font_size: '26sp'
                bold: True
                color: utils.get_color_from_hex('#e8e8e8')
                halign: 'center'
                valign: 'middle'
                text_size: self.size

        # ── Body ───────────────────────────────────────────────
        BoxLayout:
            orientation: 'vertical'
            padding: ['50dp', '28dp', '50dp', '20dp']
            spacing: '18dp'

            # Old Password
            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: None
                height: '54dp'
                spacing: '16dp'
                Label:
                    text: 'Old Password'
                    font_size: '22sp'
                    color: utils.get_color_from_hex('#a0a0a0')
                    size_hint_x: None
                    width: '210dp'
                    halign: 'right'
                    valign: 'middle'
                    text_size: self.size
                TextInput:
                    id: old_pw
                    password: True
                    multiline: False
                    font_size: '20sp'
                    foreground_color: utils.get_color_from_hex('#e8e8e8')
                    background_color: utils.get_color_from_hex('#3e3e3e')
                    cursor_color: utils.get_color_from_hex('#6BB562')
                    hint_text: ''
                    size_hint_y: None
                    height: '50dp'
                    padding: ['12dp', '10dp']

            # New Password
            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: None
                height: '54dp'
                spacing: '16dp'
                Label:
                    text: 'New Password'
                    font_size: '22sp'
                    color: utils.get_color_from_hex('#a0a0a0')
                    size_hint_x: None
                    width: '210dp'
                    halign: 'right'
                    valign: 'middle'
                    text_size: self.size
                TextInput:
                    id: new_pw
                    password: True
                    multiline: False
                    font_size: '20sp'
                    foreground_color: utils.get_color_from_hex('#e8e8e8')
                    background_color: utils.get_color_from_hex('#3e3e3e')
                    cursor_color: utils.get_color_from_hex('#6BB562')
                    hint_text: ''
                    size_hint_y: None
                    height: '50dp'
                    padding: ['12dp', '10dp']

            # Confirm Password
            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: None
                height: '54dp'
                spacing: '16dp'
                Label:
                    text: 'Confirm Password'
                    font_size: '22sp'
                    color: utils.get_color_from_hex('#a0a0a0')
                    size_hint_x: None
                    width: '210dp'
                    halign: 'right'
                    valign: 'middle'
                    text_size: self.size
                TextInput:
                    id: confirm_pw
                    password: True
                    multiline: False
                    font_size: '20sp'
                    foreground_color: utils.get_color_from_hex('#e8e8e8')
                    background_color: utils.get_color_from_hex('#3e3e3e')
                    cursor_color: utils.get_color_from_hex('#6BB562')
                    hint_text: ''
                    size_hint_y: None
                    height: '50dp'
                    padding: ['12dp', '10dp']

            # Error label (hidden when empty)
            Label:
                text: root.error_msg
                font_size: '18sp'
                color: utils.get_color_from_hex('#d9534f')
                size_hint_y: None
                height: '30dp'
                opacity: 1 if root.error_msg else 0
                halign: 'center'
                text_size: self.size

            Widget:

            # ── Buttons ────────────────────────────────────────
            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: None
                height: '60dp'
                spacing: '20dp'
                padding: ['60dp', '0dp', '60dp', '0dp']

                Button:
                    text: 'Cancel'
                    font_size: '22sp'
                    background_normal: ''
                    background_color: (0, 0, 0, 0)
                    color: utils.get_color_from_hex('#a0a0a0')
                    on_release: root.dismiss()
                    canvas.before:
                        Color:
                            rgba: utils.get_color_from_hex('#555555') if self.state == 'down' else utils.get_color_from_hex('#3e3e3e')
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [10]

                Button:
                    text: 'Confirm'
                    font_size: '22sp'
                    background_normal: ''
                    background_color: (0, 0, 0, 0)
                    color: (1, 1, 1, 1)
                    on_release: root.submit_data()
                    canvas.before:
                        Color:
                            rgba: utils.get_color_from_hex('#4aa84a') if self.state == 'down' else utils.get_color_from_hex('#6BB562')
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [10]
