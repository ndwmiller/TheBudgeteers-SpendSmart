#:import utils kivy.utils

<ChangePassword>:
    size_hint: None, None
    size: dp(350), dp(400)
    auto_dismiss: True

    background: ''
    background_color: [0, 0, 0, 0] 

    BoxLayout:
        orientation: 'vertical'

        # header label
        Label:
            pos_hint: {'center_x': .5, 'center_y': .5}
            text: "Change Password"
            font_size: '20sp'
            color: utils.get_color_from_hex('#656565')
            halign: 'center'
            valign: 'middle'
            text_size: self.size
            size_hint: None, None
            width: dp(270)
            height: dp(35)

            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex('#D7D7D7')
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: (dp(15), dp(15), 0, 0)

            canvas.after:
                Color:
                    rgba: utils.get_color_from_hex('#6BB562')
                Line:
                    width: dp(1)
                    rounded_rectangle: (self.x, self.y, self.width, self.height, dp(15), dp(15), 0, 0)

        # Body container
        BoxLayout:
            orientation: 'vertical'
            padding: dp(20)
            #spacing: dp(15)

            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex('#D7D7D7')
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(15)]

            canvas.after:
                Color:
                    rgba: utils.get_color_from_hex('#6BB562')
                Line:
                    width: dp(1)
                    rounded_rectangle: (self.x, self.y, self.width, self.height, dp(15))
            
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: dp(280)
                pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                spacing: dp(30)
                

                # Old Password row
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: dp(60)

                    Label:
                        pos_hint: {'center_x': .5, 'center_y': .5}
                        text: "Old\nPassword"
                        font_size: '18sp'
                        color: utils.get_color_from_hex('#6BB562')
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                        size_hint_x: 0.3

                    TextInput:
                        id: old_pw
                        background_normal: ''
                        hint_text: '...'
                        pos_hint: {'center_x': .5, 'center_y': .5}
                        password: True
                        multiline: False
                        write_tab: False
                        halign: 'left'
                        padding_y: [self.height / 2.0 - (self.line_height / 2.0), 0]
                        on_text: root.clear_error()
                        size_hint_x: 0.65
                        size_hint_y: None
                        height: dp(40)

                        canvas.after:
                            Color:
                                rgba: utils.get_color_from_hex('#6BB562')
                            Line:
                                width: 1.2
                                rectangle: (self.x, self.y, self.width, self.height)

                # New Password row
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: dp(60)

                    Label:
                        pos_hint: {'center_x': .5, 'center_y': .5}
                        text: "New\nPassword"
                        font_size: '18sp'
                        color: utils.get_color_from_hex('#6BB562')
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                        size_hint_x: 0.3

                    TextInput:
                        id: new_pw
                        background_normal: ''
                        hint_text: '...'
                        pos_hint: {'center_x': .5, 'center_y': .5}
                        password: True
                        multiline: False
                        write_tab: False
                        halign: 'left'
                        padding_y: [self.height / 2.0 - (self.line_height / 2.0), 0]
                        on_text: root.clear_error()
                        size_hint_x: 0.65
                        size_hint_y: None
                        height: dp(40)

                        canvas.after:
                            Color:
                                rgba: utils.get_color_from_hex('#6BB562')
                            Line:
                                width: 1.2
                                rectangle: (self.x, self.y, self.width, self.height)

                # Confirm Password row
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: dp(60)

                    Label:
                        pos_hint: {'center_x': .5, 'center_y': .5}
                        text: "Confirm\nPassword"
                        font_size: '18sp'
                        color: utils.get_color_from_hex('#6BB562')
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                        size_hint_x: 0.3

                    TextInput:
                        id: confirm_pw
                        background_normal: ''
                        hint_text: '...'
                        pos_hint: {'center_x': .5, 'center_y': .5}
                        password: True
                        multiline: False
                        write_tab: False
                        halign: 'left'
                        padding_y: [self.height / 2.0 - (self.line_height / 2.0), 0]
                        on_text: root.clear_error()
                        size_hint_x: 0.65
                        size_hint_y: None
                        height: dp(40)

                        canvas.after:
                            Color:
                                rgba: utils.get_color_from_hex('#6BB562')
                            Line:
                                width: 1.2
                                rectangle: (self.x, self.y, self.width, self.height)

            # Validation error label — matches add_bill.kv exactly
            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: None
                height: dp(15)
                Label:
                    id: error_label
                    text: ""
                    color: utils.get_color_from_hex('#e44949')
                    font_size: '14sp'
                    size_hint_y: None
                    height: dp(20) if self.text else 0
                    halign: 'center'
            
            Widget:
                size_hint_y: None
                height: dp(15)

            # ── Cancel / Confirm buttons — matches add_bill.kv ─
            BoxLayout:
                size_hint_y: None
                height: dp(50)
                spacing: dp(10)
                padding: [0, dp(10), 0, 0]

                # Cancel button
                Button:
                    pos_hint: {'center_x': .5, 'center_y': .5}
                    background_normal: ''
                    background_down: ''
                    background_color: utils.get_color_from_hex('#d7d7d7') if self.state == 'down' else utils.get_color_from_hex('#ffffff')
                    color: utils.get_color_from_hex('#6BB562')
                    font_size: '18sp'
                    size_hint_y: None
                    height: dp(30)
                    text_size: self.size
                    halign: 'center'
                    valign: 'middle'
                    text: "Cancel"
                    on_release: root.dismiss()

                    canvas.after:
                        Color:
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: dp(1)
                            rectangle: (self.x, self.y, self.width, self.height)

                # Confirm button — green fill, same as Add button in add_bill.kv
                Button:
                    pos_hint: {'center_x': .5, 'center_y': .5}
                    background_normal: ''
                    background_down: ''
                    background_color: utils.get_color_from_hex('#abff80') if self.state == 'down' else utils.get_color_from_hex('#DAFFC8')
                    color: utils.get_color_from_hex('#6BB562')
                    font_size: '18sp'
                    size_hint_y: None
                    height: dp(30)
                    text_size: self.size
                    halign: 'center'
                    valign: 'middle'
                    text: "Confirm"
                    on_release: root.submit_data()

                    canvas.after:
                        Color:
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: dp(1)
                            rectangle: (self.x, self.y, self.width, self.height)
