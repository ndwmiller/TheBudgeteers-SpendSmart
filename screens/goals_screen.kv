                            width: 1.2
                            points: [self.right, self.y, self.right, self.top]
                Label:
                    text: '$ XXXX.XX'
                    color: TEXT_GREEN
                    font_size: '19sp'
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_x: 1.2
                    canvas.after:
                        Color:
                            rgba: BORDER
                        Line:
                            width: 1.2
                            points: [self.right, self.y, self.right, self.top]
                Label:
                    text: '$ XXX.XX'
                    color: TEXT_GREEN
                    font_size: '19sp'
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_x: 1.2
