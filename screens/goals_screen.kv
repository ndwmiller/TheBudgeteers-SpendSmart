                Label:
                    text: '$ XXXX.XX'
                    color: TEXT_GREEN
                    font_size: '19sp'
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_x: 1.2
                    canvas.after:
