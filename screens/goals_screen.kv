                            height: dp(32)
                            Label:
                                text: 'Goal Name'
                                color: TEXT_GREEN
                                font_size: '19sp'
                                size_hint_x: 0.42
                                halign: 'right'
                                valign: 'middle'
                                text_size: self.size
                            TextInput:
                                multiline: False
                                hint_text: '...'
                                hint_text_color: TEXT_HINT
                                foreground_color: TEXT_DARK
                                background_normal: ''
                                background_active: ''
                                background_color: 1, 1, 1, 1
                                size_hint_x: 0.58
                                padding: [dp(6), dp(6), dp(6), dp(6)]
                                canvas.after:
                                    Color:
                                        rgba: BORDER
                                    Line:
                                        width: 1.2
                                        rectangle: (self.x, self.y, self.width, self.height)

                        BoxLayout:
                            spacing: dp(10)
                            size_hint_y: None
                            height: dp(32)
                            Label:
                                text: 'Target Amount'
                                color: TEXT_GREEN
                                font_size: '19sp'
                                size_hint_x: 0.42
                                halign: 'right'
                                valign: 'middle'
                                text_size: self.size
                            TextInput:
                                multiline: False
