#:import utils kivy.utils
#:import dp kivy.metrics.dp
#:import DateInput screens.widgets.date_input.DateInput
#:set TEXT_RED utils.get_color_from_hex('#d9534f')

<GoalAmountInput>:
    orientation: 'horizontal'
    spacing: 0
    size_hint_y: None
    height: dp(30)
    text: ''
    canvas.before:
        Color:
            rgba: utils.get_color_from_hex('#ffffff')
        Rectangle:
            pos: self.pos
            size: self.size
    canvas.after:
        Color:
            rgba: utils.get_color_from_hex('#6BB562')
        Line:
            width: 1.2
            rectangle: (self.x, self.y, self.width, self.height)
    Label:
        text: '$'
        color: utils.get_color_from_hex('#519D4A')
        font_size: '14sp'
        size_hint_x: None
        width: dp(24)
        halign: 'center'
        valign: 'middle'
        text_size: self.size
    TextInput:
        id: amount_text
        text: root.text
        multiline: False
        hint_text: '0.00'
        hint_text_color: utils.get_color_from_hex('#B7B7B7')
        foreground_color: utils.get_color_from_hex('#656565')
        background_normal: ''
        background_active: ''
        background_color: 1, 1, 1, 0
        input_filter: 'float'
        padding: [dp(2), (self.height - self.line_height) / 2, dp(6), 0]
        on_text: root.sync_text(self)

<GoalRow>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(39)
    spacing: 0
    canvas.before:
        Color:
            rgba: utils.get_color_from_hex('#6BB562')
        Line:
            width: 1.0
            points: [self.x, self.top, self.right, self.top]

    # Name
    Label:
        text: root.goal_name
        color: utils.get_color_from_hex('#519D4A')
        font_size: '19sp'
        halign: 'center'
        valign: 'middle'
        text_size: self.size
        size_hint_x: 1

    # Target Amount
    Label:
        text: root.goal_amount
        color: utils.get_color_from_hex('#519D4A')
        font_size: '19sp'
        halign: 'center'
        valign: 'middle'
        text_size: self.size
        size_hint_x: 1

    # Saved
    Label:
        text: root.goal_saved
        color: utils.get_color_from_hex('#519D4A')
        font_size: '19sp'
        halign: 'center'
        valign: 'middle'
        text_size: self.size
        size_hint_x: 1

    # Target Date
    Label:
        text: root.goal_date
        color: utils.get_color_from_hex('#519D4A')
        font_size: '19sp'
        halign: 'center'
        valign: 'middle'
        text_size: self.size
        size_hint_x: 1

    # Progress bar
    BoxLayout:
        size_hint_x: 1
        padding: [dp(10), dp(7), dp(10), dp(7)]
        spacing: dp(5)
        BoxLayout:
            size_hint_x: 1
            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex('#D7D7D7') if app.theme == 'light' else utils.get_color_from_hex('#4D4D4D')
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: utils.get_color_from_hex('#DAFFC8')
                Rectangle:
                    pos: self.pos
                    size: [self.width * min(root.progress_ratio, 1.0), self.height]
                Color:
                    rgba: utils.get_color_from_hex('#6BB562')
                Line:
                    width: 1.2
                    rectangle: (self.x, self.y, self.width, self.height)
        Label:
            text: root.progress_text
            color: utils.get_color_from_hex('#519D4A')
            font_size: '14sp'
            size_hint_x: None
            width: dp(54)
            halign: 'center'
            valign: 'middle'
            text_size: self.size

    # Trash delete button
    Button:
        size_hint: None, None
        size: dp(30), dp(30)
        pos_hint: {'center_y': 0.5}
        background_normal: app.base_path + '/resources/Images/trash_icon.png'
        background_down: app.base_path + '/resources/Images/trash_icon.png'
        background_color: (1, 1, 1, 1)
        border: (0, 0, 0, 0)
        on_release: root.on_delete()

<GoalsScreen>:
    BoxLayout:
        orientation: 'vertical'
        size_hint: 1, 1
        padding: [dp(30), dp(48), dp(30), dp(30)]
        spacing: 0
        canvas.before:
            Color:
                rgba: (0.8, 0.8, 0.8, 1) if app.theme == 'light' else utils.get_color_from_hex('#4D4D4D')
            Rectangle:
                pos: self.pos
                size: self.size

        # ── Goals table ────────────────────────────────────────
        AnchorLayout:
            size_hint_y: None
            height: dp(30)
            anchor_x: 'left'
            anchor_y: 'top'

            BoxLayout:
                size_hint: None, None
                width: goals_table.width
                height: dp(30)
                BoxLayout:
                    size_hint: None, None
                    width: (goals_table.width - dp(44)) / 5
                    height: dp(30)
                    canvas.before:
                        Color:
                            rgba: utils.get_color_from_hex('#D7D7D7')
                        Rectangle:
                            pos: self.pos
                            size: self.size
                        Color:
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: 1.2
                            rectangle: (self.x, self.y, self.width, self.height)
                    Label:
                        text: 'Goals'
                        color: utils.get_color_from_hex('#656565')
                        font_size: '20sp'
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                Widget:

        # Fixed-height table with ScrollView for rows
        BoxLayout:
            id: goals_table
            orientation: 'vertical'
            size_hint_x: 1
            size_hint_y: None
            # fixed height: header + 5 rows always
            height: dp(39) + dp(39) * 5
            spacing: 0
            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex('#D7D7D7')
                Rectangle:
                    pos: self.pos
                    size: self.size
            canvas.after:
                Color:
                    rgba: utils.get_color_from_hex('#6BB562')
                Line:
                    width: 1.2
                    rectangle: (self.x, self.y, self.width, self.height)
                Line:
                    width: 1.2
                    points: [self.x + (self.width - dp(44)) * (1 / 5), self.y, self.x + (self.width - dp(44)) * (1 / 5), self.top]
                Line:
                    width: 1.2
                    points: [self.x + (self.width - dp(44)) * (2 / 5), self.y, self.x + (self.width - dp(44)) * (2 / 5), self.top]
                Line:
                    width: 1.2
                    points: [self.x + (self.width - dp(44)) * (3 / 5), self.y, self.x + (self.width - dp(44)) * (3 / 5), self.top]
                Line:
                    width: 1.2
                    points: [self.x + (self.width - dp(44)) * (4 / 5), self.y, self.x + (self.width - dp(44)) * (4 / 5), self.top]
                Line:
                    width: 1.2
                    points: [self.x, self.top - dp(39), self.right, self.top - dp(39)]

            # Header row
            BoxLayout:
                size_hint_y: None
                height: dp(39)
                spacing: 0
                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex('#D7D7D7')
                    Rectangle:
                        pos: self.pos
                        size: self.size

                Label:
                    text: 'Name'
                    color: utils.get_color_from_hex('#656565')
                    font_size: '19sp'
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_x: 1
                    canvas.after:
                        Color:
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: 1.2
                            points: [self.right, self.y, self.right, self.top]

                Label:
                    text: 'Target Amount'
                    color: utils.get_color_from_hex('#656565')
                    font_size: '19sp'
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_x: 1
                    canvas.after:
                        Color:
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: 1.2
                            points: [self.right, self.y, self.right, self.top]

                Label:
                    text: 'Saved'
                    color: utils.get_color_from_hex('#656565')
                    font_size: '19sp'
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_x: 1
                    canvas.after:
                        Color:
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: 1.2
                            points: [self.right, self.y, self.right, self.top]

                Label:
                    text: 'Target Date'
                    color: utils.get_color_from_hex('#656565')
                    font_size: '19sp'
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_x: 1
                    canvas.after:
                        Color:
                            rgba: utils.get_color_from_hex('#6BB562')
                        Line:
                            width: 1.2
                            points: [self.right, self.y, self.right, self.top]

                Label:
                    text: 'Progress'
                    color: utils.get_color_from_hex('#656565')
                    font_size: '19sp'
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_x: 1

                # Delete column header
                Label:
                    text: ''
                    size_hint_x: None
                    width: dp(44)

            # Scrollable rows — fixed 5-row visible height
            ScrollView:
                size_hint_y: None
                height: dp(39) * 5
                do_scroll_x: False
                do_scroll_y: True
                bar_width: dp(4)
                bar_color: utils.get_color_from_hex('#6BB562')
                bar_inactive_color: utils.get_color_from_hex('#D7D7D7')

                GridLayout:
                    id: goals_rows_grid
                    cols: 1
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: 0

        Widget:
            size_hint_y: None
            height: dp(26)

        # ── Forms row ──────────────────────────────────────────
        AnchorLayout:
            size_hint_y: 1
            anchor_x: 'center'
            anchor_y: 'top'

            BoxLayout:
                size_hint: 0.807, None
                height: self.minimum_height
                spacing: dp(160)

                # ── Add Goal panel ─────────────────────────────
                BoxLayout:
                    orientation: 'vertical'
                    size_hint: 1, None
                    height: self.minimum_height
                    spacing: 0

                    AnchorLayout:
                        size_hint_y: None
                        height: dp(32)
                        anchor_x: 'center'
                        anchor_y: 'top'
                        BoxLayout:
                            size_hint: None, None
                            width: dp(182)
                            height: dp(32)
                            canvas.before:
                                Color:
                                    rgba: utils.get_color_from_hex('#D7D7D7')
                                Rectangle:
                                    pos: self.pos
                                    size: self.size
                                Color:
                                    rgba: utils.get_color_from_hex('#6BB562')
                                Line:
                                    width: 1.2
                                    rectangle: (self.x, self.y, self.width, self.height)
                            Label:
                                text: 'Add Goal'
                                color: utils.get_color_from_hex('#656565')
                                font_size: '19sp'
                                halign: 'center'
                                valign: 'middle'
                                text_size: self.size

                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height
                        padding: [dp(70), dp(18), dp(70), dp(14)]
                        spacing: dp(18)
                        canvas.before:
                            Color:
                                rgba: utils.get_color_from_hex('#D7D7D7')
                            Rectangle:
                                pos: self.pos
                                size: self.size
                            Color:
                                rgba: utils.get_color_from_hex('#6BB562')
                            Line:
                                width: 1.2
                                rectangle: (self.x, self.y, self.width, self.height)

                        # Goal Name
                        BoxLayout:
                            spacing: dp(10)
                            size_hint_y: None
                            height: dp(30)
                            Label:
                                text: 'Goal Name'
                                color: utils.get_color_from_hex('#519D4A')
                                font_size: '14sp'
                                size_hint_x: 0.42
                                halign: 'right'
                                valign: 'middle'
                                text_size: self.size
                            TextInput:
                                id: add_goal_name
                                multiline: False
                                hint_text: '...'
                                hint_text_color: utils.get_color_from_hex('#B7B7B7')
                                foreground_color: utils.get_color_from_hex('#656565')
                                background_normal: ''
                                background_active: ''
                                background_color: utils.get_color_from_hex('#ffffff')
                                size_hint_x: 0.58
                                padding: [dp(6), (self.height - self.line_height) / 2, dp(6), 0]
                                canvas.after:
                                    Color:
                                        rgba: utils.get_color_from_hex('#6BB562')
                                    Line:
                                        width: 1.2
                                        rectangle: (self.x, self.y, self.width, self.height)

                        # Target Amount
                        BoxLayout:
                            spacing: dp(10)
                            size_hint_y: None
                            height: dp(30)
                            Label:
                                text: 'Target Amount'
                                color: utils.get_color_from_hex('#519D4A')
                                font_size: '14sp'
                                size_hint_x: 0.42
                                halign: 'right'
                                valign: 'middle'
                                text_size: self.size
                            GoalAmountInput:
                                id: add_goal_amount
                                size_hint_x: 0.58

                        # Completion Date
                        BoxLayout:
                            spacing: dp(10)
                            size_hint_y: None
                            height: dp(30)
                            Label:
                                text: 'Completion Date'
                                color: utils.get_color_from_hex('#519D4A')
                                font_size: '14sp'
                                size_hint_x: 0.42
                                halign: 'right'
                                valign: 'middle'
                                text_size: self.size
                            DateInput:
                                id: add_goal_date
                                hint_text: 'MM/DD/YYYY'
                                multiline: False
                                background_normal: ''
                                background_active: ''
                                background_color: utils.get_color_from_hex('#ffffff')
                                foreground_color: utils.get_color_from_hex('#656565')
                                hint_text_color: utils.get_color_from_hex('#B7B7B7')
                                size_hint_x: 0.58
                                padding: [dp(6), (self.height - self.line_height) / 2, dp(6), 0]
                                canvas.after:
                                    Color:
                                        rgba: utils.get_color_from_hex('#6BB562')
                                    Line:
                                        width: 1.2
                                        rectangle: (self.x, self.y, self.width, self.height)

                        # Error label
                        Label:
                            id: add_error_label
                            text: ''
                            color: TEXT_RED
                            font_size: '13sp'
                            size_hint_y: None
                            height: dp(16)
                            halign: 'center'
                            valign: 'middle'
                            text_size: self.size

                        Button:
                            text: 'Add'
                            size_hint_y: None
                            height: dp(30)
                            background_normal: ''
                            background_down: ''
                            background_color: utils.get_color_from_hex('#DAFFC8')
                            color: utils.get_color_from_hex('#519D4A')
                            on_release: root.add_goal()
                            canvas.after:
                                Color:
                                    rgba: utils.get_color_from_hex('#6BB562')
                                Line:
                                    width: 1.2
                                    rectangle: (self.x, self.y, self.width, self.height)

                # ── Update Goal panel ──────────────────────────
                BoxLayout:
                    orientation: 'vertical'
                    size_hint: 1, None
                    height: self.minimum_height
                    spacing: 0

                    AnchorLayout:
                        size_hint_y: None
                        height: dp(32)
                        anchor_x: 'center'
                        anchor_y: 'top'
                        BoxLayout:
                            size_hint: None, None
                            width: dp(182)
                            height: dp(32)
                            canvas.before:
                                Color:
                                    rgba: utils.get_color_from_hex('#D7D7D7')
                                Rectangle:
                                    pos: self.pos
                                    size: self.size
                                Color:
                                    rgba: utils.get_color_from_hex('#6BB562')
                                Line:
                                    width: 1.2
                                    rectangle: (self.x, self.y, self.width, self.height)
                            Label:
                                text: 'Update Goal'
                                color: utils.get_color_from_hex('#656565')
                                font_size: '19sp'
                                halign: 'center'
                                valign: 'middle'
                                text_size: self.size

                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height
                        padding: [dp(70), dp(14), dp(70), dp(14)]
                        spacing: dp(10)
                        canvas.before:
                            Color:
                                rgba: utils.get_color_from_hex('#D7D7D7')
                            Rectangle:
                                pos: self.pos
                                size: self.size
                            Color:
                                rgba: utils.get_color_from_hex('#6BB562')
                            Line:
                                width: 1.2
                                rectangle: (self.x, self.y, self.width, self.height)

                        # Goal selector
                        BoxLayout:
                            spacing: dp(10)
                            size_hint_y: None
                            height: dp(30)
                            Label:
                                text: 'Goal'
                                color: utils.get_color_from_hex('#519D4A')
                                font_size: '14sp'
                                size_hint_x: 0.42
                                halign: 'right'
                                valign: 'middle'
                                text_size: self.size
                            Spinner:
                                id: update_goal_spinner
                                text: 'Select a goal...'
                                values: []
                                background_normal: ''
                                background_down: ''
                                background_color: utils.get_color_from_hex('#ffffff')
                                color: utils.get_color_from_hex('#B7B7B7')
                                size_hint_x: 0.58
                                on_text: root.load_goal_into_update_form(self.text)
                                canvas.after:
                                    Color:
                                        rgba: utils.get_color_from_hex('#6BB562')
                                    Line:
                                        width: 1.2
                                        rectangle: (self.x, self.y, self.width, self.height)

                        # Target Amount
                        BoxLayout:
                            spacing: dp(10)
                            size_hint_y: None
                            height: dp(30)
                            Label:
                                text: 'Target Amount'
                                color: utils.get_color_from_hex('#519D4A')
                                font_size: '14sp'
                                size_hint_x: 0.42
                                halign: 'right'
                                valign: 'middle'
                                text_size: self.size
                            GoalAmountInput:
                                id: update_goal_amount
                                size_hint_x: 0.58

                        # Saved Amount
                        BoxLayout:
                            spacing: dp(10)
                            size_hint_y: None
                            height: dp(30)
                            Label:
                                text: 'Saved Amount'
                                color: utils.get_color_from_hex('#519D4A')
                                font_size: '14sp'
                                size_hint_x: 0.42
                                halign: 'right'
                                valign: 'middle'
                                text_size: self.size
                            GoalAmountInput:
                                id: update_goal_saved
                                size_hint_x: 0.58

                        # Completion Date
                        BoxLayout:
                            spacing: dp(10)
                            size_hint_y: None
                            height: dp(30)
                            Label:
                                text: 'Completion Date'
                                color: utils.get_color_from_hex('#519D4A')
                                font_size: '14sp'
                                size_hint_x: 0.42
                                halign: 'right'
                                valign: 'middle'
                                text_size: self.size
                            DateInput:
                                id: update_goal_date
                                hint_text: 'MM/DD/YYYY'
                                multiline: False
                                background_normal: ''
                                background_active: ''
                                background_color: utils.get_color_from_hex('#ffffff')
                                foreground_color: utils.get_color_from_hex('#656565')
                                hint_text_color: utils.get_color_from_hex('#B7B7B7')
                                size_hint_x: 0.58
                                padding: [dp(6), (self.height - self.line_height) / 2, dp(6), 0]
                                canvas.after:
                                    Color:
                                        rgba: utils.get_color_from_hex('#6BB562')
                                    Line:
                                        width: 1.2
                                        rectangle: (self.x, self.y, self.width, self.height)

                        # Error label
                        Label:
                            id: update_error_label
                            text: ''
                            color: TEXT_RED
                            font_size: '13sp'
                            size_hint_y: None
                            height: dp(16)
                            halign: 'center'
                            valign: 'middle'
                            text_size: self.size

                        Button:
                            text: 'Save'
                            size_hint_y: None
                            height: dp(30)
                            background_normal: ''
                            background_down: ''
                            background_color: utils.get_color_from_hex('#DAFFC8')
                            color: utils.get_color_from_hex('#519D4A')
                            on_release: root.save_goal()
                            canvas.after:
                                Color:
                                    rgba: utils.get_color_from_hex('#6BB562')
                                Line:
                                    width: 1.2
                                    rectangle: (self.x, self.y, self.width, self.height)


