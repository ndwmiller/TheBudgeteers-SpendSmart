                                color: TEXT_DARK
                                font_size: '19sp'
                                halign: 'center'
                                valign: 'middle'
                                text_size: self.size

                    BoxLayout:
                        orientation: 'vertical'
                        padding: [dp(22), dp(10), dp(22), dp(14)]
                        spacing: dp(10)
                        canvas.before:
                            Color:
                                rgba: BG_LIGHT
                            Rectangle:
                                pos: self.pos
                                size: self.size
                            Color:
                                rgba: BORDER
                            Line:
