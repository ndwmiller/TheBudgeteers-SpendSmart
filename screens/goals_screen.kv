        # Forms row
        AnchorLayout:
            size_hint_y: None
            height: dp(280)
            anchor_x: 'center'
            anchor_y: 'center'

            BoxLayout:
                size_hint: None, None
                width: dp(820)
                height: dp(280)
                spacing: dp(52)

                # Add Goal panel
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_x: None
                    width: dp(384)
                    spacing: 0

                    AnchorLayout:
                        size_hint_y: None
                        height: dp(32)
                        anchor_x: 'center'
                        anchor_y: 'top'

                        BoxLayout:
                            size_hint: None, None
                            width: dp(182)
                            height: dp(32)
                            canvas.before:
                                Color:
                                    rgba: BG_LIGHT
                                Rectangle:
                                    pos: self.pos
                                    size: self.size
                                Color:
                                    rgba: BORDER
                                Line:
                                    width: 1.2
                                    rectangle: (self.x, self.y, self.width, self.height)
                            Label:
                                text: 'Add Goal'
                                color: TEXT_DARK
                                font_size: '19sp'
                                halign: 'center'
                                valign: 'middle'
                                text_size: self.size

                    BoxLayout:
                        orientation: 'vertical'
                        padding: [dp(22), dp(10), dp(22), dp(14)]
                        spacing: dp(12)
                        canvas.before:
                            Color:
                                rgba: BG_LIGHT
                            Rectangle:
                                pos: self.pos
                                size: self.size
                            Color:
                                rgba: BORDER
                            Line:
