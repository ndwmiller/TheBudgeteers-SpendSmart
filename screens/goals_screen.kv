                                        rgba: BORDER
                                    Line:
                                        width: 1.2
                                        rectangle: (self.x, self.y, self.width, self.height)

                        Widget:

                        Button:
                            text: 'Add'
                            size_hint_y: None
                            height: dp(30)
                            background_normal: ''
                            background_down: ''
                            background_color: BTN_BG
                            color: TEXT_GREEN
                            canvas.after:
                                Color:
                                    rgba: BORDER
                                Line:
                                    width: 1.2
                                    rectangle: (self.x, self.y, self.width, self.height)

                # Update Goal panel
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_x: None
                    width: dp(384)
                    spacing: 0

                    AnchorLayout:
                        size_hint_y: None
                        height: dp(32)
