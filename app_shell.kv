<AppShell>:
    # orientation: 

    # screen manager
    ScreenManager:
        id: sm
        DashboardScreen:
            name: 'dashboard'
        BudgetScreen:
            name: 'budget'
        TransactionsScreen:
            name: 'transactions'
        SettingsScreen:
            name: 'settings'
        GoalsScreen:
            name: 'goals'
    
    # nav bar goes here (persistent)